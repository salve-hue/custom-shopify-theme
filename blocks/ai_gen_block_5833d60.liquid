{% doc %}
  @prompt
    An announcement bar where I can customize the font size, text color, background color, and width.
    
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-announcement-bar__container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: 12px 20px;
    text-align: center;
  }

  .ai-announcement-bar__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    margin: 0;
    line-height: 1.4;
  }

  .ai-announcement-bar__link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    display: block;
  }

  .ai-announcement-bar__link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-bar__container-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-announcement-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-announcement-bar__container-{{ ai_gen_id }}">
    {% if block.settings.link != blank %}
      <a href="{{ block.settings.link }}" class="ai-announcement-bar__link-{{ ai_gen_id }}">
        <p class="ai-announcement-bar__text-{{ ai_gen_id }}">{{ block.settings.text }}</p>
      </a>
    {% else %}
      <p class="ai-announcement-bar__text-{{ ai_gen_id }}">{{ block.settings.text }}</p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text",
      "default": "Welcome to our store"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ],
  "tag": null
}
{% endschema %}
