{% doc %}
  @prompt
    A simple image upload, crop, and download tool. The image types allowed are JPG, JPEG, PNG, TIF, and TIFF.
    
    The user should be prompted to upload a file, drag and drop a file, or paste a URL to the image file.
    
    The tool should display the image file, and set a fixed crop window at a 49:29 aspect ratio. This ratio is based on the uploaded image's resolution. This is a fixed crop window, which means the user can move it around to crop an area, but they cannot resize it.
    
    Once the window is in place, the user can crop the image, and download it at full resolution to their phone or PC., the tool should have options for me to edit the layout, make it wider.
    
    The user should see a preview of the image they uploaded while cropping., no URL option
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-crop-tool-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-crop-tool__heading-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 30px;
    color: {{ block.settings.text_color }};
    font-size: 32px;
  }

  .ai-image-crop-tool__upload-area-{{ ai_gen_id }} {
    border: 2px dashed {{ block.settings.border_color }};
    border-radius: 12px;
    padding: 60px 40px;
    text-align: center;
    background-color: {{ block.settings.upload_bg_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 30px;
  }

  .ai-image-crop-tool__upload-area-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.primary_color }};
    background-color: {{ block.settings.upload_hover_bg }};
  }

  .ai-image-crop-tool__upload-area-{{ ai_gen_id }}.dragging {
    border-color: {{ block.settings.primary_color }};
    background-color: {{ block.settings.upload_hover_bg }};
  }

  .ai-image-crop-tool__upload-icon-{{ ai_gen_id }} {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    color: {{ block.settings.primary_color }};
  }

  .ai-image-crop-tool__upload-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 18px;
    margin-bottom: 10px;
  }

  .ai-image-crop-tool__upload-subtext-{{ ai_gen_id }} {
    color: {{ block.settings.subtext_color }};
    font-size: 14px;
  }

  .ai-image-crop-tool__file-input-{{ ai_gen_id }} {
    display: none;
  }

  .ai-image-crop-tool__crop-container-{{ ai_gen_id }} {
    display: none;
    margin-top: 30px;
  }

  .ai-image-crop-tool__crop-container-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-image-crop-tool__canvas-wrapper-{{ ai_gen_id }} {
    position: relative;
    max-width: 100%;
    margin: 0 auto 20px;
    overflow: hidden;
    background-color: #f0f0f0;
    border-radius: 8px;
    display: inline-block;
  }

  .ai-image-crop-tool__canvas-{{ ai_gen_id }} {
    display: block;
    max-width: 100%;
    cursor: move;
  }

  .ai-image-crop-tool__crop-window-{{ ai_gen_id }} {
    position: absolute;
    border: 2px solid {{ block.settings.primary_color }};
    box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.5);
    cursor: move;
    pointer-events: none;
  }

  .ai-image-crop-tool__crop-window-inner-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border: 1px dashed rgba(255, 255, 255, 0.5);
  }

  .ai-image-crop-tool__controls-{{ ai_gen_id }} {
    text-align: center;
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ai-image-crop-tool__button-{{ ai_gen_id }} {
    padding: 12px 30px;
    background-color: {{ block.settings.primary_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 16px;
    transition: background-color 0.3s ease;
  }

  .ai-image-crop-tool__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_hover_color }};
  }

  .ai-image-crop-tool__button-{{ ai_gen_id }}--secondary {
    background-color: {{ block.settings.secondary_color }};
  }

  .ai-image-crop-tool__button-{{ ai_gen_id }}--secondary:hover {
    background-color: {{ block.settings.secondary_hover_color }};
  }

  .ai-image-crop-tool__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    text-align: center;
    margin-top: 15px;
    font-size: 14px;
    display: none;
  }

  .ai-image-crop-tool__error-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-image-crop-tool__upload-area-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-image-crop-tool__controls-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-image-crop-tool__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<image-crop-tool-{{ ai_gen_id }} class="ai-image-crop-tool-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <h2 class="ai-image-crop-tool__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>

  <div class="ai-image-crop-tool__upload-area-{{ ai_gen_id }}" data-upload-area>
    <svg class="ai-image-crop-tool__upload-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
    </svg>
    <div class="ai-image-crop-tool__upload-text-{{ ai_gen_id }}">{{ block.settings.upload_text }}</div>
    <div class="ai-image-crop-tool__upload-subtext-{{ ai_gen_id }}">{{ block.settings.upload_subtext }}</div>
    <input 
      type="file" 
      class="ai-image-crop-tool__file-input-{{ ai_gen_id }}" 
      accept=".jpg,.jpeg,.png,.tif,.tiff"
      data-file-input
    >
  </div>

  <div class="ai-image-crop-tool__error-{{ ai_gen_id }}" data-error></div>

  <div class="ai-image-crop-tool__crop-container-{{ ai_gen_id }}" data-crop-container>
    <div class="ai-image-crop-tool__canvas-wrapper-{{ ai_gen_id }}" data-canvas-wrapper>
      <canvas class="ai-image-crop-tool__canvas-{{ ai_gen_id }}" data-canvas></canvas>
      <div class="ai-image-crop-tool__crop-window-{{ ai_gen_id }}" data-crop-window>
        <div class="ai-image-crop-tool__crop-window-inner-{{ ai_gen_id }}"></div>
      </div>
    </div>
    <div class="ai-image-crop-tool__controls-{{ ai_gen_id }}">
      <button class="ai-image-crop-tool__button-{{ ai_gen_id }}" data-crop-button>
        {{ block.settings.crop_button_text }}
      </button>
      <button class="ai-image-crop-tool__button-{{ ai_gen_id }} ai-image-crop-tool__button-{{ ai_gen_id }}--secondary" data-reset-button>
        {{ block.settings.reset_button_text }}
      </button>
    </div>
  </div>
</image-crop-tool-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageCropTool{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.aspectRatio = 49 / 29;
        this.originalImage = null;
        this.isDragging = false;
        this.dragStartX = 0;
        this.dragStartY = 0;
        this.cropX = 0;
        this.cropY = 0;
        this.allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/tiff'];
      }

      connectedCallback() {
        this.uploadArea = this.querySelector('[data-upload-area]');
        this.fileInput = this.querySelector('[data-file-input]');
        this.cropContainer = this.querySelector('[data-crop-container]');
        this.canvas = this.querySelector('[data-canvas]');
        this.ctx = this.canvas.getContext('2d');
        this.cropWindow = this.querySelector('[data-crop-window]');
        this.canvasWrapper = this.querySelector('[data-canvas-wrapper]');
        this.cropButton = this.querySelector('[data-crop-button]');
        this.resetButton = this.querySelector('[data-reset-button]');
        this.errorElement = this.querySelector('[data-error]');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.uploadArea.addEventListener('click', () => {
          this.fileInput.click();
        });

        this.uploadArea.addEventListener('dragover', (e) => {
          e.preventDefault();
          this.uploadArea.classList.add('dragging');
        });

        this.uploadArea.addEventListener('dragleave', () => {
          this.uploadArea.classList.remove('dragging');
        });

        this.uploadArea.addEventListener('drop', (e) => {
          e.preventDefault();
          this.uploadArea.classList.remove('dragging');
          const file = e.dataTransfer.files[0];
          if (file) {
            this.handleFile(file);
          }
        });

        this.fileInput.addEventListener('change', (e) => {
          const file = e.target.files[0];
          if (file) {
            this.handleFile(file);
          }
        });

        document.addEventListener('paste', (e) => {
          const items = e.clipboardData.items;
          for (let i = 0; i < items.length; i++) {
            if (items[i].type.indexOf('image') !== -1) {
              const file = items[i].getAsFile();
              this.handleFile(file);
              break;
            }
          }
        });

        this.canvasWrapper.addEventListener('mousedown', (e) => {
          this.startDrag(e);
        });

        this.canvasWrapper.addEventListener('touchstart', (e) => {
          this.startDrag(e.touches[0]);
        });

        document.addEventListener('mousemove', (e) => {
          this.drag(e);
        });

        document.addEventListener('touchmove', (e) => {
          if (this.isDragging) {
            e.preventDefault();
            this.drag(e.touches[0]);
          }
        });

        document.addEventListener('mouseup', () => {
          this.endDrag();
        });

        document.addEventListener('touchend', () => {
          this.endDrag();
        });

        this.cropButton.addEventListener('click', () => {
          this.cropAndDownload();
        });

        this.resetButton.addEventListener('click', () => {
          this.reset();
        });
      }

      handleFile(file) {
        if (!this.allowedTypes.includes(file.type)) {
          this.showError('Please upload a JPG, JPEG, PNG, TIF, or TIFF file.');
          return;
        }

        const reader = new FileReader();
        reader.onload = (e) => {
          this.loadImage(e.target.result);
        };
        reader.readAsDataURL(file);
      }

      loadImage(src) {
        this.hideError();
        const img = new Image();
        img.onload = () => {
          this.originalImage = img;
          this.displayImage();
        };
        img.src = src;
      }

      displayImage() {
        const img = this.originalImage;
        const maxWidth = Math.min(this.canvasWrapper.parentElement.offsetWidth - 40, 1200);
        const scale = maxWidth / img.width;
        const displayWidth = img.width * scale;
        const displayHeight = img.height * scale;

        this.canvas.width = displayWidth;
        this.canvas.height = displayHeight;
        this.ctx.drawImage(img, 0, 0, displayWidth, displayHeight);

        const cropWidth = Math.min(displayWidth * 0.8, displayWidth);
        const cropHeight = cropWidth / this.aspectRatio;

        if (cropHeight > displayHeight) {
          const adjustedHeight = displayHeight * 0.8;
          const adjustedWidth = adjustedHeight * this.aspectRatio;
          this.cropWindow.style.width = adjustedWidth + 'px';
          this.cropWindow.style.height = adjustedHeight + 'px';
        } else {
          this.cropWindow.style.width = cropWidth + 'px';
          this.cropWindow.style.height = cropHeight + 'px';
        }

        this.cropX = (displayWidth - parseFloat(this.cropWindow.style.width)) / 2;
        this.cropY = (displayHeight - parseFloat(this.cropWindow.style.height)) / 2;
        this.updateCropWindow();

        this.cropContainer.classList.add('active');
      }

      startDrag(e) {
        this.isDragging = true;
        const rect = this.canvasWrapper.getBoundingClientRect();
        this.dragStartX = (e.clientX || e.pageX) - rect.left - this.cropX;
        this.dragStartY = (e.clientY || e.pageY) - rect.top - this.cropY;
      }

      drag(e) {
        if (!this.isDragging) return;

        const rect = this.canvasWrapper.getBoundingClientRect();
        let newX = (e.clientX || e.pageX) - rect.left - this.dragStartX;
        let newY = (e.clientY || e.pageY) - rect.top - this.dragStartY;

        const cropWidth = parseFloat(this.cropWindow.style.width);
        const cropHeight = parseFloat(this.cropWindow.style.height);

        newX = Math.max(0, Math.min(newX, this.canvas.width - cropWidth));
        newY = Math.max(0, Math.min(newY, this.canvas.height - cropHeight));

        this.cropX = newX;
        this.cropY = newY;
        this.updateCropWindow();
      }

      endDrag() {
        this.isDragging = false;
      }

      updateCropWindow() {
        this.cropWindow.style.left = this.cropX + 'px';
        this.cropWindow.style.top = this.cropY + 'px';
      }

      cropAndDownload() {
        const cropWidth = parseFloat(this.cropWindow.style.width);
        const cropHeight = parseFloat(this.cropWindow.style.height);

        const scaleX = this.originalImage.width / this.canvas.width;
        const scaleY = this.originalImage.height / this.canvas.height;

        const sourceX = this.cropX * scaleX;
        const sourceY = this.cropY * scaleY;
        const sourceWidth = cropWidth * scaleX;
        const sourceHeight = cropHeight * scaleY;

        const outputCanvas = document.createElement('canvas');
        outputCanvas.width = sourceWidth;
        outputCanvas.height = sourceHeight;
        const outputCtx = outputCanvas.getContext('2d');

        outputCtx.drawImage(
          this.originalImage,
          sourceX,
          sourceY,
          sourceWidth,
          sourceHeight,
          0,
          0,
          sourceWidth,
          sourceHeight
        );

        outputCanvas.toBlob((blob) => {
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'cropped-image-49x29.jpg';
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          URL.revokeObjectURL(url);
        }, 'image/jpeg', 1.0);
      }

      reset() {
        this.cropContainer.classList.remove('active');
        this.originalImage = null;
        this.fileInput.value = '';
        this.hideError();
      }

      showError(message) {
        this.errorElement.textContent = message;
        this.errorElement.classList.add('active');
      }

      hideError() {
        this.errorElement.textContent = '';
        this.errorElement.classList.remove('active');
      }
    }

    customElements.define('image-crop-tool-{{ ai_gen_id }}', ImageCropTool{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image crop tool",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
