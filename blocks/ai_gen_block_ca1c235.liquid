{% doc %}
  @prompt
    A custom area to highlight a product that I can customize the placement of images and the description. Almost like a new features product area.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-highlight-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-highlight-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-highlight-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.grid_gap }}px;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .ai-product-highlight-grid-{{ ai_gen_id }} {
      grid-template-columns: {% if block.settings.layout == 'image-left' %}{{ block.settings.image_width }}% 1fr{% else %}1fr {{ block.settings.image_width }}%{% endif %};
    }
  }

  .ai-product-highlight-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    {% if block.settings.layout == 'image-right' %}
      order: 2;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-product-highlight-image-wrapper-{{ ai_gen_id }} {
      order: 1;
    }
  }

  .ai-product-highlight-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-product-highlight-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-product-highlight-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-product-highlight-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-product-highlight-content-{{ ai_gen_id }} {
    {% if block.settings.layout == 'image-right' %}
      order: 1;
    {% else %}
      order: 2;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-product-highlight-content-{{ ai_gen_id }} {
      order: 2;
    }
  }

  .ai-product-highlight-badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 16px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    border-radius: {{ block.settings.badge_border_radius }}px;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-product-highlight-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-product-highlight-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .ai-product-highlight-features-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
  }

  .ai-product-highlight-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
  }

  .ai-product-highlight-feature-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
  }

  .ai-product-highlight-feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.accent_color }};
  }

  .ai-product-highlight-price-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 24px;
  }

  .ai-product-highlight-price-current-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
  }

  .ai-product-highlight-price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    text-decoration: line-through;
    opacity: 0.7;
  }

  .ai-product-highlight-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-product-highlight-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-highlight-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-product-highlight-price-current-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.price_size }}px * 0.85);
    }
  }
{% endstyle %}

<div class="ai-product-highlight-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-highlight-container-{{ ai_gen_id }}">
    <div class="ai-product-highlight-grid-{{ ai_gen_id }}">
      <div class="ai-product-highlight-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 1200 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
            class="ai-product-highlight-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-product-highlight-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
            <div class="ai-product-highlight-empty-state-{{ ai_gen_id }}">
              Add a product image
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-product-highlight-content-{{ ai_gen_id }}">
        {% if block.settings.badge_text != blank %}
          <div class="ai-product-highlight-badge-{{ ai_gen_id }}">
            {{ block.settings.badge_text }}
          </div>
        {% endif %}

        {% if block.settings.title != blank %}
          <h2 class="ai-product-highlight-title-{{ ai_gen_id }}">
            {{ block.settings.title }}
          </h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-product-highlight-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}

        {% if block.settings.show_features %}
          <ul class="ai-product-highlight-features-{{ ai_gen_id }}">
            {% if block.settings.feature_1 != blank %}
              <li class="ai-product-highlight-feature-{{ ai_gen_id }}">
                <span class="ai-product-highlight-feature-icon-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </span>
                <span>{{ block.settings.feature_1 }}</span>
              </li>
            {% endif %}
            {% if block.settings.feature_2 != blank %}
              <li class="ai-product-highlight-feature-{{ ai_gen_id }}">
                <span class="ai-product-highlight-feature-icon-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </span>
                <span>{{ block.settings.feature_2 }}</span>
              </li>
            {% endif %}
            {% if block.settings.feature_3 != blank %}
              <li class="ai-product-highlight-feature-{{ ai_gen_id }}">
                <span class="ai-product-highlight-feature-icon-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </span>
                <span>{{ block.settings.feature_3 }}</span>
              </li>
            {% endif %}
            {% if block.settings.feature_4 != blank %}
              <li class="ai-product-highlight-feature-{{ ai_gen_id }}">
                <span class="ai-product-highlight-feature-icon-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </span>
                <span>{{ block.settings.feature_4 }}</span>
              </li>
            {% endif %}
          </ul>
        {% endif %}

        {% if block.settings.show_price and block.settings.price != blank %}
          <div class="ai-product-highlight-price-{{ ai_gen_id }}">
            <span class="ai-product-highlight-price-current-{{ ai_gen_id }}">
              {{ block.settings.price }}
            </span>
            {% if block.settings.compare_price != blank %}
              <span class="ai-product-highlight-price-compare-{{ ai_gen_id }}">
                {{ block.settings.compare_price }}
              </span>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a
            href="{{ block.settings.button_link }}"
            class="ai-product-highlight-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product highlight",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image position",
      "options": [
        {
          "value": "image-left",
          "label": "Left"
        },
        {
          "value": "image-right",
          "label": "Right"
        }
      ],
      "default": "image-left"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "label": "Image width",
      "default": 50
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1400,
      "step": 100,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 20,
      "max": 80,
      "step": 10,
      "unit": "px",
      "label": "Space between image and content",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Vertical padding",
      "default": 60
    },
    {
      "type": "header",
      "content": "Product image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Border radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "New"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 12
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 4
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Background",
      "default": "#02b6fa"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Introducing Our Latest Product"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 40
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover the perfect blend of innovation and quality. This product is designed to exceed your expectations with cutting-edge features and exceptional performance.</p>"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "checkbox",
      "id": "show_features",
      "label": "Show features",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "Premium quality materials"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Advanced technology"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Eco-friendly design"
    },
    {
      "type": "text",
      "id": "feature_4",
      "label": "Feature 4",
      "default": "1-year warranty included"
    },
    {
      "type": "header",
      "content": "Price"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "$99.99"
    },
    {
      "type": "text",
      "id": "compare_price",
      "label": "Compare at price"
    },
    {
      "type": "range",
      "id": "price_size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Price size",
      "default": 32
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 6
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Hover background",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#02b6fa"
    }
  ],
  "presets": [
    {
      "name": "Product highlight"
    }
  ]
}
{% endschema %}
