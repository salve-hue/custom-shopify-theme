{% doc %}
  @prompt
    A simple calculator for users to determine the discount they receive. It should have fields for the number of playmats why want to buy, and if it's between 10 and 19 they get 10% off, 20 and 49 they get 20% off, and 50 or more is 33% off. If they enter 100 or more, it should point them to the bulk order form page.
    
    It needs a field for the user to type in the price of the mat so the discount can calculate properly. 
    
    When you list the discount table, only list it as two columns: column one with the header minimum quantity, and column two with the header Discount. Then list it as 10, 20, 50 with the respective percentage discount.
    
    The calculator should be wide and not tall, with price and quantity on the left, and the math and discount table on the right., Move the minimum quantity and discount table in the middle and calculations to the far right.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-discount-calculator-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    max-width: 100%;
  }

  .ai-discount-calculator__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .ai-discount-calculator__left-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-discount-calculator__middle-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-discount-calculator__right-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-discount-calculator__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 20px 0;
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-discount-calculator__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-discount-calculator__label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: 600;
  }

  .ai-discount-calculator__input-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 16px;
    width: 100%;
  }

  .ai-discount-calculator__input-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.primary_color }};
    outline-offset: 2px;
  }

  .ai-discount-calculator__results-{{ ai_gen_id }} {
    background-color: {{ block.settings.results_bg_color }};
    padding: 20px;
    border-radius: {{ block.settings.input_border_radius }}px;
    border: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-discount-calculator__result-row-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    color: {{ block.settings.text_color }};
    font-size: 16px;
  }

  .ai-discount-calculator__result-row-{{ ai_gen_id }}:not(:last-child) {
    border-bottom: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-discount-calculator__result-label-{{ ai_gen_id }} {
    font-weight: 500;
  }

  .ai-discount-calculator__result-value-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.primary_color }};
  }

  .ai-discount-calculator__total-{{ ai_gen_id }} {
    font-size: 20px;
    margin-top: 8px;
  }

  .ai-discount-calculator__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
  }

  .ai-discount-calculator__table-{{ ai_gen_id }} th {
    background-color: {{ block.settings.table_header_bg }};
    color: {{ block.settings.text_color }};
    padding: 12px;
    text-align: left;
    font-weight: 600;
    font-size: 14px;
    border: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-discount-calculator__table-{{ ai_gen_id }} td {
    padding: 12px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    border: 1px solid {{ block.settings.input_border_color }};
  }

  .ai-discount-calculator__bulk-notice-{{ ai_gen_id }} {
    background-color: {{ block.settings.notice_bg_color }};
    color: {{ block.settings.notice_text_color }};
    padding: 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    display: none;
  }

  .ai-discount-calculator__bulk-notice-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-discount-calculator__bulk-notice-{{ ai_gen_id }} a {
    color: {{ block.settings.notice_link_color }};
    text-decoration: underline;
    font-weight: 600;
  }

  @media screen and (max-width: 989px) {
    .ai-discount-calculator__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }

    .ai-discount-calculator__right-{{ ai_gen_id }} {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-discount-calculator__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-discount-calculator__right-{{ ai_gen_id }} {
      grid-column: auto;
    }
  }
{% endstyle %}

<discount-calculator-{{ ai_gen_id }}
  class="ai-discount-calculator-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-discount-calculator__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-discount-calculator__container-{{ ai_gen_id }}">
    <div class="ai-discount-calculator__left-{{ ai_gen_id }}">
      <div class="ai-discount-calculator__field-{{ ai_gen_id }}">
        <label
          for="price-input-{{ ai_gen_id }}"
          class="ai-discount-calculator__label-{{ ai_gen_id }}"
        >
          Price per mat
        </label>
        <input
          type="number"
          id="price-input-{{ ai_gen_id }}"
          class="ai-discount-calculator__input-{{ ai_gen_id }}"
          placeholder="0.00"
          step="0.01"
          min="0"
          data-price-input
        >
      </div>

      <div class="ai-discount-calculator__field-{{ ai_gen_id }}">
        <label
          for="quantity-input-{{ ai_gen_id }}"
          class="ai-discount-calculator__label-{{ ai_gen_id }}"
        >
          Number of playmats
        </label>
        <input
          type="number"
          id="quantity-input-{{ ai_gen_id }}"
          class="ai-discount-calculator__input-{{ ai_gen_id }}"
          placeholder="0"
          min="0"
          step="1"
          data-quantity-input
        >
      </div>
    </div>

    <div class="ai-discount-calculator__middle-{{ ai_gen_id }}">
      <table class="ai-discount-calculator__table-{{ ai_gen_id }}">
        <thead>
          <tr>
            <th>Minimum quantity</th>
            <th>Discount</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>10</td>
            <td>10%</td>
          </tr>
          <tr>
            <td>20</td>
            <td>20%</td>
          </tr>
          <tr>
            <td>50</td>
            <td>33%</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="ai-discount-calculator__right-{{ ai_gen_id }}">
      <div class="ai-discount-calculator__results-{{ ai_gen_id }}">
        <div class="ai-discount-calculator__result-row-{{ ai_gen_id }}">
          <span class="ai-discount-calculator__result-label-{{ ai_gen_id }}">Subtotal:</span>
          <span
            class="ai-discount-calculator__result-value-{{ ai_gen_id }}"
            data-subtotal
          >$0.00</span>
        </div>
        <div class="ai-discount-calculator__result-row-{{ ai_gen_id }}">
          <span class="ai-discount-calculator__result-label-{{ ai_gen_id }}">Discount:</span>
          <span
            class="ai-discount-calculator__result-value-{{ ai_gen_id }}"
            data-discount-percent
          >0%</span>
        </div>
        <div class="ai-discount-calculator__result-row-{{ ai_gen_id }}">
          <span class="ai-discount-calculator__result-label-{{ ai_gen_id }}">Savings:</span>
          <span
            class="ai-discount-calculator__result-value-{{ ai_gen_id }}"
            data-savings
          >$0.00</span>
        </div>
        <div class="ai-discount-calculator__result-row-{{ ai_gen_id }} ai-discount-calculator__total-{{ ai_gen_id }}">
          <span class="ai-discount-calculator__result-label-{{ ai_gen_id }}">Total:</span>
          <span
            class="ai-discount-calculator__result-value-{{ ai_gen_id }}"
            data-total
          >$0.00</span>
        </div>
      </div>

      <div
        class="ai-discount-calculator__bulk-notice-{{ ai_gen_id }}"
        data-bulk-notice
      >
        For orders of 100 or more playmats, please visit our <a href="{{ block.settings.bulk_order_link }}">bulk order form</a>.
      </div>
    </div>
  </div>
</discount-calculator-{{ ai_gen_id }}>

<script>
  (function() {
    class DiscountCalculator{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.priceInput = this.querySelector('[data-price-input]');
        this.quantityInput = this.querySelector('[data-quantity-input]');
        this.subtotalEl = this.querySelector('[data-subtotal]');
        this.discountPercentEl = this.querySelector('[data-discount-percent]');
        this.savingsEl = this.querySelector('[data-savings]');
        this.totalEl = this.querySelector('[data-total]');
        this.bulkNotice = this.querySelector('[data-bulk-notice]');
      }

      connectedCallback() {
        this.priceInput.addEventListener('input', () => this.calculate());
        this.quantityInput.addEventListener('input', () => this.calculate());
      }

      calculate() {
        const price = parseFloat(this.priceInput.value) || 0;
        const quantity = parseInt(this.quantityInput.value) || 0;

        const subtotal = price * quantity;
        let discountPercent = 0;

        if (quantity >= 50) {
          discountPercent = 33;
        } else if (quantity >= 20) {
          discountPercent = 20;
        } else if (quantity >= 10) {
          discountPercent = 10;
        }

        const savings = subtotal * (discountPercent / 100);
        const total = subtotal - savings;

        this.subtotalEl.textContent = '$' + subtotal.toFixed(2);
        this.discountPercentEl.textContent = discountPercent + '%';
        this.savingsEl.textContent = '$' + savings.toFixed(2);
        this.totalEl.textContent = '$' + total.toFixed(2);

        if (quantity >= 100) {
          this.bulkNotice.classList.add('active');
        } else {
          this.bulkNotice.classList.remove('active');
        }
      }
    }

    customElements.define('discount-calculator-{{ ai_gen_id }}', DiscountCalculator{{ ai_gen_id }});
  })();
</script>

