      "label": "Notice background",
      "default": "#e1edf5"
    },
    {
      "type": "color",
      "id": "notice_text_color",
      "label": "Notice text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "notice_link_color",
      "label": "Notice link",
