{% doc %}
  @prompt
    Create a vertical list of Gaming Essential add-ons for buyers to add to their bundle. It should pull from the Gaming Essentials collection or have the option to choose which collection to choose., If a product in the collection has a variant, it should have a small dropdown to select which variant., Next to the variant dropdown, put some sort of icon or arrow to indicate it's a dropdown so it doesn't confuse buyers., Could you add a small color square next to each variant in the dropdown menus with a color matching the variant title? For instance, if it's Black, put a small color swatch black square next to it. Match the color with the closest common color of that name., Make the dropdown menu on top of any other object when expanded., When I click a dropdown menu it should be on top of everything else. It should be moved up to the top layer so it covers anything it expands over., Remove the dropdown menus from the products. Instead, when someone clicks "add to cart", pop open a lightbox with variant options to add to cart., Perfect. If it doesn't have a variant or child objects, just add it to the cart. Make sure the page doesn't need a refresh to see it in the cart and it should add it automatically.
    
    
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gaming-essentials-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-gaming-essentials__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
    font-weight: 600;
  }

  .ai-gaming-essentials__list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-gaming-essentials__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background-color: {{ block.settings.item_background_color }};
    border: 1px solid {{ block.settings.item_border_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    transition: all 0.3s ease;
  }

  .ai-gaming-essentials__item-{{ ai_gen_id }}:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-gaming-essentials__image-{{ ai_gen_id }} {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
  }

  .ai-gaming-essentials__image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-gaming-essentials__info-{{ ai_gen_id }} {
    flex-grow: 1;
    min-width: 0;
  }

  .ai-gaming-essentials__product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 4px;
  }

  .ai-gaming-essentials__price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-gaming-essentials__add-button-{{ ai_gen_id }} {
    padding: 8px 16px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    white-space: nowrap;
    transition: background-color 0.3s ease;
  }

  .ai-gaming-essentials__add-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-gaming-essentials__add-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-gaming-essentials__lightbox-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-gaming-essentials__lightbox-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-gaming-essentials__lightbox-content-{{ ai_gen_id }} {
    background-color: {{ block.settings.lightbox_background_color }};
    border-radius: {{ block.settings.lightbox_border_radius }}px;
    padding: 24px;
    max-width: 400px;
    width: 90%;
    max-height: 80vh;
    overflow-y: auto;
    position: relative;
  }

  .ai-gaming-essentials__lightbox-close-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-gaming-essentials__lightbox-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-gaming-essentials__lightbox-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    padding-right: 24px;
  }

  .ai-gaming-essentials__variant-options-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-gaming-essentials__variant-option-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px;
    background-color: {{ block.settings.item_background_color }};
    border: 1px solid {{ block.settings.item_border_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-gaming-essentials__variant-option-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    border-color: {{ block.settings.button_color }};
  }

  .ai-gaming-essentials__color-swatch-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 1px solid {{ block.settings.item_border_color }};
    flex-shrink: 0;
  }

  .ai-gaming-essentials__variant-label-{{ ai_gen_id }} {
    flex-grow: 1;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-gaming-essentials__variant-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-gaming-essentials__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  @media screen and (max-width: 749px) {
    .ai-gaming-essentials__item-{{ ai_gen_id }} {
      flex-wrap: wrap;
    }

    .ai-gaming-essentials__add-button-{{ ai_gen_id }} {
      width: 100%;
      margin-top: 8px;
    }
  }
{% endstyle %}

<gaming-essentials-{{ ai_gen_id }}
  class="ai-gaming-essentials-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-collection-handle="{{ block.settings.collection.handle }}"
>
  {% if block.settings.title != blank %}
    <h3 class="ai-gaming-essentials__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
  {% endif %}

  {% if block.settings.collection != blank %}
    <ul class="ai-gaming-essentials__list-{{ ai_gen_id }}">
      {% for product in block.settings.collection.products limit: block.settings.products_limit %}
        <li class="ai-gaming-essentials__item-{{ ai_gen_id }}" data-product-id="{{ product.id }}">
          <div class="ai-gaming-essentials__image-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 120 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="60"
                height="60"
              >
            {% else %}
              <div style="width: 100%; height: 100%; background-color: #f4f4f4;"></div>
            {% endif %}
          </div>

          <div class="ai-gaming-essentials__info-{{ ai_gen_id }}">
            <h4 class="ai-gaming-essentials__product-title-{{ ai_gen_id }}">{{ product.title }}</h4>
            <p class="ai-gaming-essentials__price-{{ ai_gen_id }}">{{ product.price | money }}</p>
          </div>

          <button
            class="ai-gaming-essentials__add-button-{{ ai_gen_id }}"
            data-product-handle="{{ product.handle }}"
            data-has-variants="{{ product.has_only_default_variant | json }}"
            data-default-variant-id="{{ product.selected_or_first_available_variant.id }}"
          >
            {{ block.settings.button_text }}
          </button>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <div class="ai-gaming-essentials__empty-state-{{ ai_gen_id }}">
      <p>Select a collection to display gaming essentials</p>
    </div>
  {% endif %}

  <div class="ai-gaming-essentials__lightbox-{{ ai_gen_id }}">
    <div class="ai-gaming-essentials__lightbox-content-{{ ai_gen_id }}">
      <button class="ai-gaming-essentials__lightbox-close-{{ ai_gen_id }}" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
      <h4 class="ai-gaming-essentials__lightbox-title-{{ ai_gen_id }}"></h4>
      <div class="ai-gaming-essentials__variant-options-{{ ai_gen_id }}"></div>
    </div>
  </div>
</gaming-essentials-{{ ai_gen_id }}>

<script>
  (function() {
    class GamingEssentials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.lightbox = this.querySelector('.ai-gaming-essentials__lightbox-{{ ai_gen_id }}');
        this.lightboxTitle = this.querySelector('.ai-gaming-essentials__lightbox-title-{{ ai_gen_id }}');
        this.variantOptionsContainer = this.querySelector('.ai-gaming-essentials__variant-options-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-gaming-essentials__lightbox-close-{{ ai_gen_id }}');
        this.currentProduct = null;
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        const addButtons = this.querySelectorAll('.ai-gaming-essentials__add-button-{{ ai_gen_id }}');
        
        addButtons.forEach(button => {
          button.addEventListener('click', (e) => this.handleAddToCart(e));
        });

        this.closeButton.addEventListener('click', () => this.closeLightbox());
        
        this.lightbox.addEventListener('click', (e) => {
          if (e.target === this.lightbox) {
            this.closeLightbox();
          }
        });
      }

      async handleAddToCart(e) {
        const button = e.currentTarget;
        const productHandle = button.dataset.productHandle;
        const hasOnlyDefaultVariant = button.dataset.hasVariants === 'true';
        const defaultVariantId = button.dataset.defaultVariantId;

        if (hasOnlyDefaultVariant) {
          await this.addToCart(defaultVariantId, button);
        } else {
          await this.fetchProductAndShowLightbox(productHandle);
        }
      }

      async fetchProductAndShowLightbox(handle) {
        try {
          const response = await fetch(`/products/${handle}.js`);
          const product = await response.json();
          this.currentProduct = product;
          this.showLightbox(product);
        } catch (error) {
          console.error('Error fetching product:', error);
        }
      }

      showLightbox(product) {
        this.lightboxTitle.textContent = product.title;
        this.variantOptionsContainer.innerHTML = '';

        product.variants.forEach(variant => {
          if (!variant.available) return;

          const option = document.createElement('div');
          option.className = 'ai-gaming-essentials__variant-option-{{ ai_gen_id }}';
          option.dataset.variantId = variant.id;

          const colorSwatch = this.createColorSwatch(variant.title);
          
          const label = document.createElement('span');
          label.className = 'ai-gaming-essentials__variant-label-{{ ai_gen_id }}';
          label.textContent = variant.title;

          const price = document.createElement('span');
          price.className = 'ai-gaming-essentials__variant-price-{{ ai_gen_id }}';
          price.textContent = this.formatMoney(variant.price);

          option.appendChild(colorSwatch);
          option.appendChild(label);
          option.appendChild(price);

          option.addEventListener('click', () => this.selectVariant(variant.id));

          this.variantOptionsContainer.appendChild(option);
        });

        this.lightbox.classList.add('active');
      }

      createColorSwatch(variantTitle) {
        const swatch = document.createElement('div');
        swatch.className = 'ai-gaming-essentials__color-swatch-{{ ai_gen_id }}';
        
        const colorMap = {
          'black': '#000000',
          'white': '#FFFFFF',
          'red': '#FF0000',
          'blue': '#0000FF',
          'green': '#008000',
          'yellow': '#FFFF00',
          'orange': '#FFA500',
          'purple': '#800080',
          'pink': '#FFC0CB',
          'brown': '#8B4513',
          'gray': '#808080',
          'grey': '#808080',
          'silver': '#C0C0C0',
          'gold': '#FFD700',
          'navy': '#000080',
          'teal': '#008080',
          'lime': '#00FF00',
          'maroon': '#800000',
          'olive': '#808000',
          'cyan': '#00FFFF',
          'magenta': '#FF00FF'
        };

        const titleLower = variantTitle.toLowerCase();
        let color = '#CCCCCC';

        for (const [colorName, colorValue] of Object.entries(colorMap)) {
          if (titleLower.includes(colorName)) {
            color = colorValue;
            break;
          }
        }

        swatch.style.backgroundColor = color;
        
        if (color === '#FFFFFF') {
          swatch.style.border = '1px solid #E0E0E0';
        }

        return swatch;
      }

      async selectVariant(variantId) {
        await this.addToCart(variantId);
        this.closeLightbox();
      }

      async addToCart(variantId, button = null) {
        if (button) {
          button.disabled = true;
          button.textContent = 'Adding...';
        }

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              id: variantId,
              quantity: 1
            })
          });

          if (response.ok) {
            await this.updateCart();
            
            if (button) {
              button.textContent = 'Added!';
              setTimeout(() => {
                button.textContent = '{{ block.settings.button_text }}';
                button.disabled = false;
              }, 2000);
            }
          } else {
            throw new Error('Failed to add to cart');
          }
        } catch (error) {
          console.error('Error adding to cart:', error);
          if (button) {
            button.textContent = 'Error';
            setTimeout(() => {
              button.textContent = '{{ block.settings.button_text }}';
              button.disabled = false;
            }, 2000);
          }
        }
      }

      async updateCart() {
        try {
          const response = await fetch('/cart.js');
          const cart = await response.json();
          
          document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', {
            bubbles: true,
            detail: { cart }
          }));

          const cartCountElements = document.querySelectorAll('[data-cart-count]');
          cartCountElements.forEach(el => {
            el.textContent = cart.item_count;
          });
        } catch (error) {
          console.error('Error updating cart:', error);
        }
      }

      closeLightbox() {
        this.lightbox.classList.remove('active');
      }

      formatMoney(cents) {
        const dollars = cents / 100;
        return '$' + dollars.toFixed(2);
      }
    }

    customElements.define('gaming-essentials-{{ ai_gen_id }}', GamingEssentials{{ ai_gen_id }});
  })();
</script>

