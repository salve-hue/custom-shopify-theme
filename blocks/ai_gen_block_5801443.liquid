{% doc %}
  @prompt
    Create a contact form that sends the information to support@rubicongamesupplies.com
    
    This is my current artist program submission form. Duplicate this.
    
    
    Name*
    How should we address you?
    Email*
    example@example.com
    Portfolio (web)*
    Link to a portfolio of your work (e.g., ArtStation, Deviant Art, Google Drive)
    How many art pieces would you initially submit (maximum 10)?*
    You can submit a minimum of 1 and a maximum of 10. Note: submitting more doesn't mean they will all get approved.
    How did you hear about our Artist Program?*
    
    All artwork must fit specific guidelines, like resolution (DPI), size, bleed margins, and so on. We provide guidance on sizing for you, but you must properly size it on your own. Are you capable of doing this?*
    
    
    Artist Program Terms & Conditions
    
    Welcome to the Rubicon Artist Program. By submitting your artwork, you agree to the following terms. This summary is designed to be easy to understand.
    
    Ownership & Rights
    
    You retain full ownership of your artwork.
    By submitting, you grant Rubicon a non-exclusive license to use your art on products like playmats, mousepads, and desk mats.
    We may resize or format your artwork to fit printing specifications, but we will not alter its core appearance.
    Commission & Payment
    
    You earn 25% of the net sale price for each product sold featuring your artwork.
    Payments are made quarterly via PayPal or Venmo.
    You may request a sales report at any time.
    Submission Guidelines
    
    You may submit up to 10 designs per calendar quarter.
    Send artwork via our upload portal or email it to: support@rubicongamesupplies.com
    Subject line: “Artist Submission – [Your Name]”
    Revoking Permission
    
    You may revoke your license at any time by emailing us.
    We will stop selling new products with your artwork within 14 business days.
    You will continue to earn commissions on any remaining inventory sold.
    
    Make each field editable. Make the subject of the email sent "Artist Program Submission"
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-artist-form-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .ai-artist-form__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 40px;
  }

  .ai-artist-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    margin: 0 0 8px 0;
    font-size: 32px;
  }

  .ai-artist-form__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 32px 0;
    font-size: 16px;
    line-height: 1.5;
  }

  .ai-artist-form__field-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-artist-form__label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.label_color }};
    font-weight: 600;
    margin-bottom: 8px;
    font-size: 14px;
  }

  .ai-artist-form__required-{{ ai_gen_id }} {
    color: {{ block.settings.required_color }};
  }

  .ai-artist-form__helper-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.helper_color }};
    font-size: 13px;
    margin-top: 4px;
  }

  .ai-artist-form__input-{{ ai_gen_id }},
  .ai-artist-form__textarea-{{ ai_gen_id }},
  .ai-artist-form__select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    font-size: 14px;
    font-family: inherit;
  }

  .ai-artist-form__input-{{ ai_gen_id }}:focus,
  .ai-artist-form__textarea-{{ ai_gen_id }}:focus,
  .ai-artist-form__select-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border }};
  }

  .ai-artist-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-artist-form__terms-{{ ai_gen_id }} {
    background-color: {{ block.settings.terms_background }};
    border: 1px solid {{ block.settings.terms_border }};
    border-radius: {{ block.settings.input_border_radius }}px;
    padding: 24px;
    margin-bottom: 24px;
  }

  .ai-artist-form__terms-title-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 16px 0;
  }

  .ai-artist-form__terms-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.6;
  }

  .ai-artist-form__terms-content-{{ ai_gen_id }} h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 16px 0 8px 0;
    color: {{ block.settings.heading_color }};
  }

  .ai-artist-form__terms-content-{{ ai_gen_id }} h3:first-child {
    margin-top: 0;
  }

  .ai-artist-form__terms-content-{{ ai_gen_id }} p {
    margin: 8px 0;
  }

  .ai-artist-form__terms-content-{{ ai_gen_id }} ul {
    margin: 8px 0;
    padding-left: 20px;
  }

  .ai-artist-form__terms-content-{{ ai_gen_id }} li {
    margin: 4px 0;
  }

  .ai-artist-form__checkbox-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .ai-artist-form__checkbox-{{ ai_gen_id }} {
    margin-top: 4px;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .ai-artist-form__checkbox-label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
  }

  .ai-artist-form__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-artist-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-artist-form__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    background-color: {{ block.settings.success_background }};
    padding: 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 16px;
    font-size: 14px;
  }

  .ai-artist-form__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    background-color: {{ block.settings.error_background }};
    padding: 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 16px;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-artist-form__container-{{ ai_gen_id }} {
      padding: 24px;
    }
  }
{% endstyle %}

<div class="ai-artist-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-artist-form__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-artist-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-artist-form__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    {%- form 'contact' -%}
      <input type="hidden" name="contact[subject]" value="{{ block.settings.email_subject }}">

      {% if form.posted_successfully? %}
        <div class="ai-artist-form__success-{{ ai_gen_id }}" id="ai-artist-form-success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="ai-artist-form__error-{{ ai_gen_id }}" id="ai-artist-form-error-{{ ai_gen_id }}">
          {{ form.errors.messages.email }}
        </div>
      {% endif %}

      <div class="ai-artist-form__field-{{ ai_gen_id }}">
        <label class="ai-artist-form__label-{{ ai_gen_id }}" for="ai-artist-name-{{ ai_gen_id }}">
          {{ block.settings.name_label }}
          {% if block.settings.name_required %}
            <span class="ai-artist-form__required-{{ ai_gen_id }}">*</span>
          {% endif %}
        </label>
        <input
          type="text"
          id="ai-artist-name-{{ ai_gen_id }}"
          name="contact[{{ block.settings.name_label }}]"
          class="ai-artist-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.name_placeholder }}"
          {% if block.settings.name_required %}required{% endif %}
        >
        {% if block.settings.name_helper != blank %}
          <span class="ai-artist-form__helper-{{ ai_gen_id }}">{{ block.settings.name_helper }}</span>
        {% endif %}
      </div>

      <div class="ai-artist-form__field-{{ ai_gen_id }}">
        <label class="ai-artist-form__label-{{ ai_gen_id }}" for="ai-artist-email-{{ ai_gen_id }}">
          {{ block.settings.email_label }}
          {% if block.settings.email_required %}
            <span class="ai-artist-form__required-{{ ai_gen_id }}">*</span>
          {% endif %}
        </label>
        <input
          type="email"
          id="ai-artist-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-artist-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.email_placeholder }}"
          autocomplete="email"
          {% if block.settings.email_required %}required{% endif %}
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="ai-artist-form-error-{{ ai_gen_id }}"
          {% endif %}
          {% if form.posted_successfully? %}
            aria-describedby="ai-artist-form-success-{{ ai_gen_id }}"
          {% endif %}
        >
      </div>

      <div class="ai-artist-form__field-{{ ai_gen_id }}">
        <label class="ai-artist-form__label-{{ ai_gen_id }}" for="ai-artist-portfolio-{{ ai_gen_id }}">
          {{ block.settings.portfolio_label }}
          {% if block.settings.portfolio_required %}
            <span class="ai-artist-form__required-{{ ai_gen_id }}">*</span>
          {% endif %}
        </label>
        <input
          type="url"
          id="ai-artist-portfolio-{{ ai_gen_id }}"
          name="contact[{{ block.settings.portfolio_label }}]"
          class="ai-artist-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.portfolio_placeholder }}"
          {% if block.settings.portfolio_required %}required{% endif %}
        >
        {% if block.settings.portfolio_helper != blank %}
          <span class="ai-artist-form__helper-{{ ai_gen_id }}">{{ block.settings.portfolio_helper }}</span>
        {% endif %}
      </div>

      <div class="ai-artist-form__field-{{ ai_gen_id }}">
        <label class="ai-artist-form__label-{{ ai_gen_id }}" for="ai-artist-pieces-{{ ai_gen_id }}">
          {{ block.settings.pieces_label }}
          {% if block.settings.pieces_required %}
            <span class="ai-artist-form__required-{{ ai_gen_id }}">*</span>
          {% endif %}
        </label>
        <select
          id="ai-artist-pieces-{{ ai_gen_id }}"
          name="contact[{{ block.settings.pieces_label }}]"
          class="ai-artist-form__select-{{ ai_gen_id }}"
          {% if block.settings.pieces_required %}required{% endif %}
        >
          <option value="">Select number of pieces</option>
          {% for i in (1..10) %}
            <option value="{{ i }}">{{ i }}</option>
          {% endfor %}
        </select>
        {% if block.settings.pieces_helper != blank %}
          <span class="ai-artist-form__helper-{{ ai_gen_id }}">{{ block.settings.pieces_helper }}</span>
        {% endif %}
      </div>

      <div class="ai-artist-form__field-{{ ai_gen_id }}">
        <label class="ai-artist-form__label-{{ ai_gen_id }}" for="ai-artist-source-{{ ai_gen_id }}">
          {{ block.settings.source_label }}
          {% if block.settings.source_required %}
            <span class="ai-artist-form__required-{{ ai_gen_id }}">*</span>
          {% endif %}
        </label>
        <input
          type="text"
          id="ai-artist-source-{{ ai_gen_id }}"
          name="contact[{{ block.settings.source_label }}]"
          class="ai-artist-form__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.source_placeholder }}"
          {% if block.settings.source_required %}required{% endif %}
        >
      </div>

      <div class="ai-artist-form__field-{{ ai_gen_id }}">
        <label class="ai-artist-form__label-{{ ai_gen_id }}" for="ai-artist-sizing-{{ ai_gen_id }}">
          {{ block.settings.sizing_label }}
          {% if block.settings.sizing_required %}
            <span class="ai-artist-form__required-{{ ai_gen_id }}">*</span>
          {% endif %}
        </label>
        <select
          id="ai-artist-sizing-{{ ai_gen_id }}"
          name="contact[{{ block.settings.sizing_label }}]"
          class="ai-artist-form__select-{{ ai_gen_id }}"
          {% if block.settings.sizing_required %}required{% endif %}
        >
          <option value="">Select an option</option>
          <option value="Yes">Yes</option>
          <option value="No">No</option>
        </select>
        {% if block.settings.sizing_helper != blank %}
          <span class="ai-artist-form__helper-{{ ai_gen_id }}">{{ block.settings.sizing_helper }}</span>
        {% endif %}
      </div>

      {% if block.settings.show_terms %}
        <div class="ai-artist-form__terms-{{ ai_gen_id }}">
          <h3 class="ai-artist-form__terms-title-{{ ai_gen_id }}">{{ block.settings.terms_title }}</h3>
          <div class="ai-artist-form__terms-content-{{ ai_gen_id }}">
            {{ block.settings.terms_content }}
          </div>
        </div>
      {% endif %}

      <button type="submit" class="ai-artist-form__button-{{ ai_gen_id }}">
        {{ block.settings.submit_button_label }}
      </button>
    {%- endform -%}
  </div>
</div>

{% schema %}
