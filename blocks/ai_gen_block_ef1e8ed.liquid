{% doc %}
  @prompt
    A repository for downloadable guides and videos to show my customers how to submit images and contact information.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-resource-repository-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-resource-repository__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-resource-repository__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-resource-repository__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
  }

  .ai-resource-repository__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    max-width: 900px;
    margin: 0 auto;
  }

  .ai-resource-repository__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    margin-top: 32px;
  }

  .ai-resource-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    border: 1px solid {{ block.settings.card_border_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-resource-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-resource-card__icon-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    background-color: {{ block.settings.icon_background }};
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .ai-resource-card__icon-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-resource-card__title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
  }

  .ai-resource-card__description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0 0 16px;
    line-height: 1.5;
  }

  .ai-resource-card__link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }

  .ai-resource-card__link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-resource-card__link-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
  }

  .ai-resource-repository__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-resource-repository__empty-icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    opacity: 0.3;
  }

  .ai-resource-repository__empty-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-resource-repository__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-resource-repository__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }
{% endstyle %}

<resource-repository-{{ ai_gen_id }}
  class="ai-resource-repository-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-resource-repository__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <div class="ai-resource-repository__header-{{ ai_gen_id }}">
        <h2 class="ai-resource-repository__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% if block.settings.description != blank %}
          <div class="ai-resource-repository__description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% liquid
      assign has_resources = false
      for i in (1..6)
        assign resource_enabled_key = 'resource_' | append: i | append: '_enabled'
        if block.settings[resource_enabled_key]
          assign has_resources = true
          break
        endif
      endfor
    %}

    {% if has_resources %}
      <div class="ai-resource-repository__grid-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign resource_enabled_key = 'resource_' | append: i | append: '_enabled'
            assign resource_type_key = 'resource_' | append: i | append: '_type'
            assign resource_title_key = 'resource_' | append: i | append: '_title'
            assign resource_description_key = 'resource_' | append: i | append: '_description'
            assign resource_link_key = 'resource_' | append: i | append: '_link'
            assign resource_button_text_key = 'resource_' | append: i | append: '_button_text'

            assign resource_enabled = block.settings[resource_enabled_key]
            assign resource_type = block.settings[resource_type_key]
            assign resource_title = block.settings[resource_title_key]
            assign resource_description = block.settings[resource_description_key]
            assign resource_link = block.settings[resource_link_key]
            assign resource_button_text = block.settings[resource_button_text_key]
          %}

          {% if resource_enabled %}
            <div class="ai-resource-card-{{ ai_gen_id }}">
              <div class="ai-resource-card__icon-{{ ai_gen_id }}">
                {% if resource_type == 'video' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                  </svg>
                {% elsif resource_type == 'pdf' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                  </svg>
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path>
                    <polyline points="13 2 13 9 20 9"></polyline>
                  </svg>
                {% endif %}
              </div>

              {% if resource_title != blank %}
                <h3 class="ai-resource-card__title-{{ ai_gen_id }}">{{ resource_title }}</h3>
              {% endif %}

              {% if resource_description != blank %}
                <div class="ai-resource-card__description-{{ ai_gen_id }}">
                  {{ resource_description }}
                </div>
              {% endif %}

              {% if resource_link != blank %}
                <a
                  href="{{ resource_link }}"
                  class="ai-resource-card__link-{{ ai_gen_id }}"
                  {% if resource_type == 'pdf' or resource_type == 'guide' %}
                    download
                  {% endif %}
                  {% if resource_type == 'video' %}
                    target="_blank"
                    rel="noopener noreferrer"
                  {% endif %}
                >
                  {% if resource_button_text != blank %}
                    {{ resource_button_text }}
                  {% else %}
                    {% if resource_type == 'video' %}
                      Watch Video
                    {% else %}
                      Download
                    {% endif %}
                  {% endif %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="7" y1="17" x2="17" y2="7"></line>
                    <polyline points="7 7 17 7 17 17"></polyline>
                  </svg>
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-resource-repository__empty-{{ ai_gen_id }}">
        <div class="ai-resource-repository__empty-icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
          </svg>
        </div>
        <p>Next, enable and configure your resources</p>
      </div>
    {% endif %}
  </div>
</resource-repository-{{ ai_gen_id }}>

<script>
  (function() {
    class ResourceRepository{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupDownloadTracking();
      }

      setupDownloadTracking() {
        const downloadLinks = this.querySelectorAll('.ai-resource-card__link-{{ ai_gen_id }}[download]');
        downloadLinks.forEach(link => {
          link.addEventListener('click', function(e) {
            const resourceTitle = this.closest('.ai-resource-card-{{ ai_gen_id }}')
              .querySelector('.ai-resource-card__title-{{ ai_gen_id }}')?.textContent || 'Resource';
            console.log('Resource downloaded:', resourceTitle);
          });
        });
      }
    }

    customElements.define('resource-repository-{{ ai_gen_id }}', ResourceRepository{{ ai_gen_id }});
  })();
</script>

