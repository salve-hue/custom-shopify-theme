            <td class="ai-bulk-discount-table__cell-{{ ai_gen_id }} ai-bulk-discount-table__discount-{{ ai_gen_id }}">{{ block.settings.row_2_discount }}</td>
          </tr>
        {% endif %}

        {% if block.settings.show_row_3 %}
