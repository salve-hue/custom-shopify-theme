              {{ block.settings.row_2_quantity }}
              {% if block.settings.row_2_is_popular and block.settings.show_badge %}
                <span class="ai-bulk-discount-table__badge-{{ ai_gen_id }}">{{ block.settings.badge_text }}</span>
