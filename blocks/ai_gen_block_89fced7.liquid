{% doc %}
  @prompt
    Create a bulk discount table with the following information. It should say Buy More, Save More. Don't list a price. Make it a two column table.
     
    Buy More, Save More!
     
     
    Buy 5 for 5% Off
    Buy 10 for 10% Off
    Buy 15 for 15% Off
    Most Popular
    Buy 20 for 20% Off
    Buy 25 for 30% Off
    Buy 30 for 40% Off, Make it a list in two columns, with the left column having the Buy X, and the right column next to it having X% off, MAke it more of a table with two columns., Make this table fully editable so I can edit each column and row, including the Most Popular tag and fonts and colors and sizes.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bulk-discount-table-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-bulk-discount-table__container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
  }

  .ai-bulk-discount-table__title-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    color: {{ block.settings.title_color }};
    margin-bottom: {{ block.settings.title_spacing }}px;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
  }

  .ai-bulk-discount-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border: {{ block.settings.table_border_width }}px solid {{ block.settings.table_border_color }};
    border-radius: {{ block.settings.table_border_radius }}px;
    overflow: hidden;
  }

  .ai-bulk-discount-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_background }};
  }

  .ai-bulk-discount-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.header_padding }}px;
    color: {{ block.settings.header_text_color }};
    font-size: {{ block.settings.header_size }}px;
    font-weight: {{ block.settings.header_weight }};
    text-align: left;
    border-bottom: {{ block.settings.header_border_width }}px solid {{ block.settings.header_border_color }};
  }

  .ai-bulk-discount-table__header-cell-{{ ai_gen_id }}:last-child {
    text-align: right;
  }

  .ai-bulk-discount-table__row-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.row_border_width }}px solid {{ block.settings.row_border_color }};
    transition: background-color 0.2s ease;
  }

  .ai-bulk-discount-table__row-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.row_hover_background }};
  }

  .ai-bulk-discount-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-bulk-discount-table__row--popular-{{ ai_gen_id }} {
    background-color: {{ block.settings.popular_background }};
    position: relative;
  }

  .ai-bulk-discount-table__row--popular-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.popular_hover_background }};
  }

  .ai-bulk-discount-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
  }

  .ai-bulk-discount-table__quantity-{{ ai_gen_id }} {
    text-align: left;
  }

  .ai-bulk-discount-table__discount-{{ ai_gen_id }} {
    font-weight: {{ block.settings.discount_weight }};
    color: {{ block.settings.discount_color }};
    text-align: right;
    font-size: {{ block.settings.discount_size }}px;
  }

  .ai-bulk-discount-table__badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    margin-left: 8px;
    vertical-align: middle;
  }

  @media screen and (max-width: 749px) {
    .ai-bulk-discount-table__container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-bulk-discount-table__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-bulk-discount-table__header-cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_size | times: 0.9 }}px;
      padding: {{ block.settings.header_padding | times: 0.8 }}px;
    }

    .ai-bulk-discount-table__cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
      padding: {{ block.settings.cell_padding | times: 0.8 }}px;
    }

    .ai-bulk-discount-table__discount-{{ ai_gen_id }} {
      font-size: {{ block.settings.discount_size | times: 0.9 }}px;
    }

    .ai-bulk-discount-table__badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-bulk-discount-table-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bulk-discount-table__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-bulk-discount-table__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}

    <table class="ai-bulk-discount-table__table-{{ ai_gen_id }}">
      {% if block.settings.show_headers %}
        <thead class="ai-bulk-discount-table__header-{{ ai_gen_id }}">
          <tr>
            <th class="ai-bulk-discount-table__header-cell-{{ ai_gen_id }}">{{ block.settings.quantity_header }}</th>
            <th class="ai-bulk-discount-table__header-cell-{{ ai_gen_id }}">{{ block.settings.discount_header }}</th>
          </tr>
        </thead>
      {% endif %}
      <tbody>
        {% if block.settings.show_row_1 %}
          <tr class="ai-bulk-discount-table__row-{{ ai_gen_id }} {% if block.settings.row_1_is_popular %}ai-bulk-discount-table__row--popular-{{ ai_gen_id }}{% endif %}">
            <td class="ai-bulk-discount-table__cell-{{ ai_gen_id }} ai-bulk-discount-table__quantity-{{ ai_gen_id }}">
              {{ block.settings.row_1_quantity }}
              {% if block.settings.row_1_is_popular and block.settings.show_badge %}
                <span class="ai-bulk-discount-table__badge-{{ ai_gen_id }}">{{ block.settings.badge_text }}</span>
              {% endif %}
            </td>
            <td class="ai-bulk-discount-table__cell-{{ ai_gen_id }} ai-bulk-discount-table__discount-{{ ai_gen_id }}">{{ block.settings.row_1_discount }}</td>
          </tr>
        {% endif %}

        {% if block.settings.show_row_2 %}
