      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "upload_bg_color",
      "label": "Upload background",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "upload_hover_bg_color",
      "label": "Upload hover background",
      "default": "#e9ecef"
    }
  ],
  "presets": [
    {
      "name": "Image crop tool"
    }
  ]
}
{% endschema %}
