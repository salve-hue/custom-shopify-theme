{% doc %}
  @prompt
    Create a custom carousel for reviews, where I can upload a JSON file and it will parse the separate reviews and list them by the information given, including the reviewer name, date, review text, and stars given.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-carousel-{{ ai_gen_id }} {
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-reviews-carousel__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-reviews-carousel__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-reviews-carousel__title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 10px;
    font-size: {{ block.settings.title_size }}px;
  }

  .ai-reviews-carousel__subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-reviews-carousel__track-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-reviews-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    transition: transform 0.5s ease;
  }

  .ai-reviews-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 calc(100% - 40px);
    min-width: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-reviews-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 calc(50% - 10px);
    }
  }

  @media screen and (min-width: 990px) {
    .ai-reviews-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 calc(33.333% - 14px);
    }
  }

  .ai-reviews-carousel__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 30px;
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-reviews-carousel__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
  }

  .ai-reviews-carousel__star-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    fill: {{ block.settings.star_color }};
  }

  .ai-reviews-carousel__star-{{ ai_gen_id }}--empty {
    fill: {{ block.settings.empty_star_color }};
  }

  .ai-reviews-carousel__text-{{ ai_gen_id }} {
    color: {{ block.settings.card_text_color }};
    margin: 0 0 20px;
    flex-grow: 1;
    font-size: 14px;
    line-height: 1.6;
  }

  .ai-reviews-carousel__author-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-reviews-carousel__name-{{ ai_gen_id }} {
    color: {{ block.settings.card_text_color }};
    font-weight: 600;
    margin: 0;
    font-size: 16px;
  }

  .ai-reviews-carousel__date-{{ ai_gen_id }} {
    color: {{ block.settings.card_text_color }};
    opacity: 0.6;
    margin: 0;
    font-size: 12px;
  }

  .ai-reviews-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-reviews-carousel__button-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-reviews-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-reviews-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-reviews-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-reviews-carousel__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .ai-reviews-carousel__dot-{{ ai_gen_id }}--active {
    opacity: 1;
  }

  .ai-reviews-carousel__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-reviews-carousel__empty-icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    opacity: 0.3;
  }

  .ai-reviews-carousel__empty-text-{{ ai_gen_id }} {
    font-size: 16px;
    margin: 0;
  }
{% endstyle %}

<reviews-carousel-{{ ai_gen_id }}
  class="ai-reviews-carousel-{{ ai_gen_id }}"
  data-json-url="{{ block.settings.reviews_json | file_url }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-reviews-carousel__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-reviews-carousel__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-reviews-carousel__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-reviews-carousel__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-reviews-carousel__track-wrapper-{{ ai_gen_id }}">
      <div class="ai-reviews-carousel__track-{{ ai_gen_id }}" data-track></div>
    </div>

    <div class="ai-reviews-carousel__controls-{{ ai_gen_id }}">
      <button
        class="ai-reviews-carousel__button-{{ ai_gen_id }}"
        data-prev
        aria-label="Previous reviews"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M12.5 15L7.5 10L12.5 5"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </button>

      <div class="ai-reviews-carousel__dots-{{ ai_gen_id }}" data-dots></div>

      <button
        class="ai-reviews-carousel__button-{{ ai_gen_id }}"
        data-next
        aria-label="Next reviews"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M7.5 15L12.5 10L7.5 5"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </button>
    </div>

    <div class="ai-reviews-carousel__empty-state-{{ ai_gen_id }}" data-empty style="display: none;">
      <svg
        class="ai-reviews-carousel__empty-icon-{{ ai_gen_id }}"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      <p class="ai-reviews-carousel__empty-text-{{ ai_gen_id }}">
        Upload a JSON file with reviews to display them here
      </p>
    </div>
  </div>
</reviews-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ReviewsCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.reviews = [];
        this.slidesPerView = 1;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');
        this.emptyState = this.querySelector('[data-empty]');
        this.jsonUrl = this.dataset.jsonUrl;

        if (this.jsonUrl) {
          this.loadReviews();
        } else {
          this.showEmptyState();
        }

        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        window.addEventListener('resize', () => this.updateSlidesPerView());
      }

      async loadReviews() {
        try {
          const response = await fetch(this.jsonUrl);
          const data = await response.json();
          
          if (data.reviews && Array.isArray(data.reviews) && data.reviews.length > 0) {
            this.reviews = data.reviews;
            this.render();
          } else {
            this.showEmptyState();
          }
        } catch (error) {
          console.error('Error loading reviews:', error);
          this.showEmptyState();
        }
      }

      showEmptyState() {
        this.emptyState.style.display = 'block';
        this.querySelector('.ai-reviews-carousel__track-wrapper-{{ ai_gen_id }}').style.display = 'none';
        this.querySelector('.ai-reviews-carousel__controls-{{ ai_gen_id }}').style.display = 'none';
      }

      render() {
        this.updateSlidesPerView();
        this.renderSlides();
        this.renderDots();
        this.updateControls();
      }

      updateSlidesPerView() {
        const width = window.innerWidth;
        if (width >= 990) {
          this.slidesPerView = 3;
        } else if (width >= 750) {
          this.slidesPerView = 2;
        } else {
          this.slidesPerView = 1;
        }
        this.updatePosition();
      }

      renderSlides() {
        this.track.innerHTML = this.reviews.map((review) => {
          const stars = this.renderStars(review.rating || 5);
          const reviewText = review.text || review.review || '';
          const reviewerName = review.name || review.reviewer || 'Anonymous';
          const reviewDate = review.date || '';

          return `
            <div class="ai-reviews-carousel__slide-{{ ai_gen_id }}">
              <div class="ai-reviews-carousel__card-{{ ai_gen_id }}">
                <div class="ai-reviews-carousel__stars-{{ ai_gen_id }}">
                  ${stars}
                </div>
                <p class="ai-reviews-carousel__text-{{ ai_gen_id }}">${this.escapeHtml(reviewText)}</p>
                <div class="ai-reviews-carousel__author-{{ ai_gen_id }}">
                  <p class="ai-reviews-carousel__name-{{ ai_gen_id }}">${this.escapeHtml(reviewerName)}</p>
                  ${reviewDate ? `<p class="ai-reviews-carousel__date-{{ ai_gen_id }}">${this.escapeHtml(reviewDate)}</p>` : ''}
                </div>
              </div>
            </div>
          `;
        }).join('');
      }

      renderStars(rating) {
        const fullStars = Math.floor(rating);
        const emptyStars = 5 - fullStars;
        let starsHtml = '';

        for (let i = 0; i < fullStars; i++) {
          starsHtml += `
            <svg class="ai-reviews-carousel__star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
            </svg>
          `;
        }

        for (let i = 0; i < emptyStars; i++) {
          starsHtml += `
            <svg class="ai-reviews-carousel__star-{{ ai_gen_id }} ai-reviews-carousel__star-{{ ai_gen_id }}--empty" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
            </svg>
          `;
        }

        return starsHtml;
      }

      renderDots() {
        const totalPages = Math.ceil(this.reviews.length / this.slidesPerView);
        this.dotsContainer.innerHTML = Array.from({ length: totalPages }, (_, i) => {
          const activeClass = i === this.currentIndex ? 'ai-reviews-carousel__dot-{{ ai_gen_id }}--active' : '';
          return `<button class="ai-reviews-carousel__dot-{{ ai_gen_id }} ${activeClass}" data-index="${i}" aria-label="Go to page ${i + 1}"></button>`;
        }).join('');

        this.dotsContainer.querySelectorAll('[data-index]').forEach((dot) => {
          dot.addEventListener('click', () => {
            this.currentIndex = parseInt(dot.dataset.index);
            this.updatePosition();
            this.updateControls();
          });
        });
      }

      updatePosition() {
        const slideWidth = 100 / this.slidesPerView;
        const offset = -this.currentIndex * slideWidth;
        this.track.style.transform = `translateX(${offset}%)`;
      }

      updateControls() {
        const totalPages = Math.ceil(this.reviews.length / this.slidesPerView);
        
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= totalPages - 1;

        this.dotsContainer.querySelectorAll('.ai-reviews-carousel__dot-{{ ai_gen_id }}').forEach((dot, i) => {
          if (i === this.currentIndex) {
            dot.classList.add('ai-reviews-carousel__dot-{{ ai_gen_id }}--active');
          } else {
            dot.classList.remove('ai-reviews-carousel__dot-{{ ai_gen_id }}--active');
          }
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updatePosition();
          this.updateControls();
        }
      }

      next() {
        const totalPages = Math.ceil(this.reviews.length / this.slidesPerView);
        if (this.currentIndex < totalPages - 1) {
          this.currentIndex++;
          this.updatePosition();
          this.updateControls();
        }
      }

      escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }
    }

    customElements.define('reviews-carousel-{{ ai_gen_id }}', ReviewsCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Reviews carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Customer reviews"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "See what our customers are saying"
    },
    {
      "type": "url",
      "id": "reviews_json",
      "label": "Reviews JSON file"
    },
    {
      "type": "paragraph",
      "content": "Upload a JSON file with the following structure: {\"reviews\": [{\"name\": \"John Doe\", \"date\": \"2025-01-15\", \"rating\": 5, \"text\": \"Great product!\"}]}"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 32
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 12
    },
    {
      "type": "header",
      "content": "Stars"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#FFD700"
    },
    {
      "type": "color",
      "id": "empty_star_color",
      "label": "Empty star color",
      "default": "#E0E0E0"
    },
    {
      "type": "header",
      "content": "Controls"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button icon color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Reviews carousel"
    }
  ]
}
{% endschema %}
