{% doc %}
  @prompt
    I need a basic tool that has multiple functions.
    1) Allows the user to upload an image file for submission. The tool should only allow jpg, jpeg, png, tif, and tiff file types. The file size limit should be 22 megabytes. The tool should give them the option to crop the image at a 49:29 aspect ratio.
    2) Once the image is cropped, there should be form fields so the user can enter some information. Field 1 is their Name, field 2 is their email address, and field three is for their order number. Email address is required.
    , the second field is the user's name, the third field is for the user's email address, and the fourth field is for the user's order number.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-upload-tool-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-upload-tool__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    font-size: 28px;
    text-align: center;
  }

  .ai-image-upload-tool__step-{{ ai_gen_id }} {
    display: none;
  }

  .ai-image-upload-tool__step-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-image-upload-tool__upload-area-{{ ai_gen_id }} {
    border: 2px dashed {{ block.settings.border_color }};
    border-radius: 8px;
    padding: 60px 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    background-color: {{ block.settings.upload_area_bg }};
  }

  .ai-image-upload-tool__upload-area-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.primary_color }};
    background-color: {{ block.settings.upload_area_hover_bg }};
  }

  .ai-image-upload-tool__upload-area-{{ ai_gen_id }}.drag-over {
    border-color: {{ block.settings.primary_color }};
    background-color: {{ block.settings.upload_area_hover_bg }};
  }

  .ai-image-upload-tool__upload-icon-{{ ai_gen_id }} {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    color: {{ block.settings.primary_color }};
  }

  .ai-image-upload-tool__upload-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 16px;
    margin-bottom: 8px;
  }

  .ai-image-upload-tool__upload-subtext-{{ ai_gen_id }} {
    color: {{ block.settings.subtext_color }};
    font-size: 14px;
  }

  .ai-image-upload-tool__file-input-{{ ai_gen_id }} {
    display: none;
  }

  .ai-image-upload-tool__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 16px;
    padding: 12px;
    background-color: {{ block.settings.error_bg }};
    border-radius: 4px;
    display: none;
  }

  .ai-image-upload-tool__error-{{ ai_gen_id }}.show {
    display: block;
  }

  .ai-image-upload-tool__crop-container-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-image-upload-tool__crop-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 700px;
    margin: 0 auto 16px;
    background-color: #000;
    border-radius: 8px;
    overflow: hidden;
  }

  .ai-image-upload-tool__crop-image-{{ ai_gen_id }} {
    max-width: 100%;
    display: block;
  }

  .ai-image-upload-tool__crop-overlay-{{ ai_gen_id }} {
    position: absolute;
    border: 2px solid {{ block.settings.primary_color }};
    cursor: move;
    box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.5);
  }

  .ai-image-upload-tool__crop-handle-{{ ai_gen_id }} {
    position: absolute;
    width: 12px;
    height: 12px;
    background-color: {{ block.settings.primary_color }};
    border: 2px solid #fff;
    border-radius: 50%;
  }

  .ai-image-upload-tool__crop-handle-{{ ai_gen_id }}.nw { top: -6px; left: -6px; cursor: nw-resize; }
  .ai-image-upload-tool__crop-handle-{{ ai_gen_id }}.ne { top: -6px; right: -6px; cursor: ne-resize; }
  .ai-image-upload-tool__crop-handle-{{ ai_gen_id }}.sw { bottom: -6px; left: -6px; cursor: sw-resize; }
  .ai-image-upload-tool__crop-handle-{{ ai_gen_id }}.se { bottom: -6px; right: -6px; cursor: se-resize; }

  .ai-image-upload-tool__crop-controls-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ai-image-upload-tool__button-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text }};
    border: none;
    border-radius: {{ block.settings.button_radius }}px;
    cursor: pointer;
    font-size: 16px;
    transition: background-color 0.3s ease;
  }

  .ai-image-upload-tool__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
  }

  .ai-image-upload-tool__button-{{ ai_gen_id }}--secondary {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_text }};
  }

  .ai-image-upload-tool__button-{{ ai_gen_id }}--secondary:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
  }

  .ai-image-upload-tool__form-{{ ai_gen_id }} {
    max-width: 500px;
    margin: 0 auto;
  }

  .ai-image-upload-tool__preview-{{ ai_gen_id }} {
    margin-bottom: 24px;
    text-align: center;
  }

  .ai-image-upload-tool__preview-image-{{ ai_gen_id }} {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin-bottom: 12px;
  }

  .ai-image-upload-tool__field-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-image-upload-tool__label-{{ ai_gen_id }} {
    display: block;
    margin-bottom: 8px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
  }

  .ai-image-upload-tool__label-{{ ai_gen_id }}--required::after {
    content: ' *';
    color: {{ block.settings.error_color }};
  }

  .ai-image-upload-tool__input-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    font-size: 16px;
    box-sizing: border-box;
  }

  .ai-image-upload-tool__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.primary_color }};
  }

  .ai-image-upload-tool__input-{{ ai_gen_id }}:disabled {
    background-color: #f5f5f5;
    color: #666;
  }

  .ai-image-upload-tool__success-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
  }

  .ai-image-upload-tool__success-icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 24px;
    color: {{ block.settings.success_color }};
  }

  .ai-image-upload-tool__success-message-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 20px;
    margin-bottom: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-image-upload-tool-{{ ai_gen_id }} {
      padding: 24px 16px;
    }

    .ai-image-upload-tool__heading-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-image-upload-tool__upload-area-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-image-upload-tool__crop-controls-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-image-upload-tool__button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<image-upload-tool-{{ ai_gen_id }} class="ai-image-upload-tool-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <h2 class="ai-image-upload-tool__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>

  <div class="ai-image-upload-tool__step-{{ ai_gen_id }} ai-image-upload-tool__step-upload-{{ ai_gen_id }} active">
    <div class="ai-image-upload-tool__upload-area-{{ ai_gen_id }}">
      <svg class="ai-image-upload-tool__upload-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
      </svg>
      <div class="ai-image-upload-tool__upload-text-{{ ai_gen_id }}">{{ block.settings.upload_text }}</div>
      <div class="ai-image-upload-tool__upload-subtext-{{ ai_gen_id }}">{{ block.settings.upload_subtext }}</div>
      <input type="file" class="ai-image-upload-tool__file-input-{{ ai_gen_id }}" accept=".jpg,.jpeg,.png,.tif,.tiff">
    </div>
    <div class="ai-image-upload-tool__error-{{ ai_gen_id }}"></div>
  </div>

  <div class="ai-image-upload-tool__step-{{ ai_gen_id }} ai-image-upload-tool__step-crop-{{ ai_gen_id }}">
    <div class="ai-image-upload-tool__crop-container-{{ ai_gen_id }}">
      <div class="ai-image-upload-tool__crop-wrapper-{{ ai_gen_id }}">
        <img class="ai-image-upload-tool__crop-image-{{ ai_gen_id }}" alt="Image to crop">
        <div class="ai-image-upload-tool__crop-overlay-{{ ai_gen_id }}">
          <div class="ai-image-upload-tool__crop-handle-{{ ai_gen_id }} nw"></div>
          <div class="ai-image-upload-tool__crop-handle-{{ ai_gen_id }} ne"></div>
          <div class="ai-image-upload-tool__crop-handle-{{ ai_gen_id }} sw"></div>
          <div class="ai-image-upload-tool__crop-handle-{{ ai_gen_id }} se"></div>
        </div>
      </div>
      <div class="ai-image-upload-tool__crop-controls-{{ ai_gen_id }}">
        <button type="button" class="ai-image-upload-tool__button-{{ ai_gen_id }} ai-image-upload-tool__button-{{ ai_gen_id }}--secondary ai-image-upload-tool__button-back-{{ ai_gen_id }}">Back</button>
        <button type="button" class="ai-image-upload-tool__button-{{ ai_gen_id }} ai-image-upload-tool__button-skip-{{ ai_gen_id }}">Skip crop</button>
        <button type="button" class="ai-image-upload-tool__button-{{ ai_gen_id }} ai-image-upload-tool__button-crop-{{ ai_gen_id }}">Apply crop</button>
      </div>
    </div>
  </div>

  <div class="ai-image-upload-tool__step-{{ ai_gen_id }} ai-image-upload-tool__step-form-{{ ai_gen_id }}">
    <div class="ai-image-upload-tool__preview-{{ ai_gen_id }}">
      <img class="ai-image-upload-tool__preview-image-{{ ai_gen_id }}" alt="Preview">
    </div>
    {%- form 'contact' -%}
      <div class="ai-image-upload-tool__form-{{ ai_gen_id }}">
        <div class="ai-image-upload-tool__field-{{ ai_gen_id }}">
          <label class="ai-image-upload-tool__label-{{ ai_gen_id }}" for="image-link-{{ ai_gen_id }}">{{ block.settings.image_link_label }}</label>
          <input 
            type="text" 
            id="image-link-{{ ai_gen_id }}" 
            name="contact[image_link]" 
            class="ai-image-upload-tool__input-{{ ai_gen_id }} ai-image-upload-tool__image-link-{{ ai_gen_id }}"
            readonly
            disabled
          >
        </div>
        <div class="ai-image-upload-tool__field-{{ ai_gen_id }}">
          <label class="ai-image-upload-tool__label-{{ ai_gen_id }}" for="name-{{ ai_gen_id }}">{{ block.settings.name_label }}</label>
          <input type="text" id="name-{{ ai_gen_id }}" name="contact[name]" class="ai-image-upload-tool__input-{{ ai_gen_id }}">
        </div>
        <div class="ai-image-upload-tool__field-{{ ai_gen_id }}">
          <label class="ai-image-upload-tool__label-{{ ai_gen_id }} ai-image-upload-tool__label-{{ ai_gen_id }}--required" for="email-{{ ai_gen_id }}">{{ block.settings.email_label }}</label>
          <input type="email" id="email-{{ ai_gen_id }}" name="contact[email]" class="ai-image-upload-tool__input-{{ ai_gen_id }}" required>
        </div>
        <div class="ai-image-upload-tool__field-{{ ai_gen_id }}">
          <label class="ai-image-upload-tool__label-{{ ai_gen_id }}" for="order-{{ ai_gen_id }}">{{ block.settings.order_label }}</label>
          <input type="text" id="order-{{ ai_gen_id }}" name="contact[order_number]" class="ai-image-upload-tool__input-{{ ai_gen_id }}">
        </div>
        <input type="hidden" name="contact[image_data]" class="ai-image-upload-tool__image-data-{{ ai_gen_id }}">
        <div class="ai-image-upload-tool__crop-controls-{{ ai_gen_id }}">
          <button type="button" class="ai-image-upload-tool__button-{{ ai_gen_id }} ai-image-upload-tool__button-{{ ai_gen_id }}--secondary ai-image-upload-tool__button-form-back-{{ ai_gen_id }}">Back</button>
          <button type="submit" class="ai-image-upload-tool__button-{{ ai_gen_id }}">{{ block.settings.submit_button_text }}</button>
        </div>
      </div>
    {%- endform -%}
  </div>

  <div class="ai-image-upload-tool__step-{{ ai_gen_id }} ai-image-upload-tool__step-success-{{ ai_gen_id }}">
    <div class="ai-image-upload-tool__success-{{ ai_gen_id }}">
      <svg class="ai-image-upload-tool__success-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div class="ai-image-upload-tool__success-message-{{ ai_gen_id }}">{{ block.settings.success_message }}</div>
      <button type="button" class="ai-image-upload-tool__button-{{ ai_gen_id }} ai-image-upload-tool__button-reset-{{ ai_gen_id }}">{{ block.settings.reset_button_text }}</button>
    </div>
  </div>
</image-upload-tool-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageUploadTool{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.aspectRatio = 49 / 29;
        this.maxFileSize = 22 * 1024 * 1024;
        this.allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/tiff'];
        this.currentStep = 'upload';
        this.originalImage = null;
        this.croppedImage = null;
        this.cropData = { x: 0, y: 0, width: 0, height: 0 };
        this.isDragging = false;
        this.isResizing = false;
        this.resizeHandle = null;
        this.dragStart = { x: 0, y: 0 };
      }

      connectedCallback() {
        this.uploadArea = this.querySelector('.ai-image-upload-tool__upload-area-{{ ai_gen_id }}');
        this.fileInput = this.querySelector('.ai-image-upload-tool__file-input-{{ ai_gen_id }}');
        this.errorDiv = this.querySelector('.ai-image-upload-tool__error-{{ ai_gen_id }}');
        this.cropImage = this.querySelector('.ai-image-upload-tool__crop-image-{{ ai_gen_id }}');
        this.cropOverlay = this.querySelector('.ai-image-upload-tool__crop-overlay-{{ ai_gen_id }}');
        this.previewImage = this.querySelector('.ai-image-upload-tool__preview-image-{{ ai_gen_id }}');
        this.imageDataInput = this.querySelector('.ai-image-upload-tool__image-data-{{ ai_gen_id }}');
        this.imageLinkInput = this.querySelector('.ai-image-upload-tool__image-link-{{ ai_gen_id }}');
        this.form = this.querySelector('form');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.uploadArea.addEventListener('click', () => this.fileInput.click());
        this.fileInput.addEventListener('change', (e) => this.handleFileSelect(e));

        this.uploadArea.addEventListener('dragover', (e) => {
          e.preventDefault();
          this.uploadArea.classList.add('drag-over');
        });

        this.uploadArea.addEventListener('dragleave', () => {
          this.uploadArea.classList.remove('drag-over');
        });

        this.uploadArea.addEventListener('drop', (e) => {
          e.preventDefault();
          this.uploadArea.classList.remove('drag-over');
          if (e.dataTransfer.files.length) {
            this.handleFile(e.dataTransfer.files[0]);
          }
        });

        this.querySelector('.ai-image-upload-tool__button-back-{{ ai_gen_id }}').addEventListener('click', () => {
          this.showStep('upload');
        });

        this.querySelector('.ai-image-upload-tool__button-skip-{{ ai_gen_id }}').addEventListener('click', () => {
          this.croppedImage = this.originalImage;
          this.showStep('form');
        });

        this.querySelector('.ai-image-upload-tool__button-crop-{{ ai_gen_id }}').addEventListener('click', () => {
          this.applyCrop();
        });

        this.querySelector('.ai-image-upload-tool__button-form-back-{{ ai_gen_id }}').addEventListener('click', () => {
          this.showStep('crop');
        });

        this.querySelector('.ai-image-upload-tool__button-reset-{{ ai_gen_id }}').addEventListener('click', () => {
          this.reset();
        });

        this.cropOverlay.addEventListener('mousedown', (e) => this.startDrag(e));
        document.addEventListener('mousemove', (e) => this.onDrag(e));
        document.addEventListener('mouseup', () => this.stopDrag());

        this.querySelectorAll('.ai-image-upload-tool__crop-handle-{{ ai_gen_id }}').forEach(handle => {
          handle.addEventListener('mousedown', (e) => this.startResize(e, handle));
        });

        this.form.addEventListener('submit', (e) => {
          e.preventDefault();
          this.handleSubmit();
        });
      }

      handleFileSelect(e) {
        const file = e.target.files[0];
        if (file) {
          this.handleFile(file);
        }
      }

      handleFile(file) {
        this.errorDiv.classList.remove('show');
        this.errorDiv.textContent = '';

        if (!this.allowedTypes.includes(file.type)) {
          this.showError('Please upload a JPG, PNG, or TIFF file.');
          return;
        }

        if (file.size > this.maxFileSize) {
          this.showError('File size must be less than 22MB.');
          return;
        }

        const reader = new FileReader();
        reader.onload = (e) => {
          this.originalImage = e.target.result;
          this.loadImageForCrop();
        };
        reader.readAsDataURL(file);
      }

      showError(message) {
        this.errorDiv.textContent = message;
        this.errorDiv.classList.add('show');
      }

      loadImageForCrop() {
        this.cropImage.src = this.originalImage;
        this.cropImage.onload = () => {
          this.initializeCropArea();
          this.showStep('crop');
        };
      }

      initializeCropArea() {
        const img = this.cropImage;
        const imgWidth = img.clientWidth;
        const imgHeight = img.clientHeight;

        let cropWidth = imgWidth * 0.8;
        let cropHeight = cropWidth / this.aspectRatio;

        if (cropHeight > imgHeight * 0.8) {
          cropHeight = imgHeight * 0.8;
          cropWidth = cropHeight * this.aspectRatio;
        }

        this.cropData = {
          x: (imgWidth - cropWidth) / 2,
          y: (imgHeight - cropHeight) / 2,
          width: cropWidth,
          height: cropHeight
        };

        this.updateCropOverlay();
      }

      updateCropOverlay() {
        this.cropOverlay.style.left = this.cropData.x + 'px';
        this.cropOverlay.style.top = this.cropData.y + 'px';
        this.cropOverlay.style.width = this.cropData.width + 'px';
        this.cropOverlay.style.height = this.cropData.height + 'px';
      }

      startDrag(e) {
        if (e.target.classList.contains('ai-image-upload-tool__crop-handle-{{ ai_gen_id }}')) {
          return;
        }
        e.preventDefault();
        this.isDragging = true;
        this.dragStart = {
          x: e.clientX - this.cropData.x,
          y: e.clientY - this.cropData.y
        };
      }

      onDrag(e) {
        if (this.isDragging) {
          const img = this.cropImage;
          let newX = e.clientX - this.dragStart.x;
          let newY = e.clientY - this.dragStart.y;

          newX = Math.max(0, Math.min(newX, img.clientWidth - this.cropData.width));
          newY = Math.max(0, Math.min(newY, img.clientHeight - this.cropData.height));

          this.cropData.x = newX;
          this.cropData.y = newY;
          this.updateCropOverlay();
        } else if (this.isResizing) {
          this.onResize(e);
        }
      }

      stopDrag() {
        this.isDragging = false;
        this.isResizing = false;
        this.resizeHandle = null;
      }

      startResize(e, handle) {
        e.preventDefault();
        e.stopPropagation();
        this.isResizing = true;
        this.resizeHandle = handle.classList.contains('nw') ? 'nw' :
                           handle.classList.contains('ne') ? 'ne' :
                           handle.classList.contains('sw') ? 'sw' : 'se';
        this.dragStart = { x: e.clientX, y: e.clientY };
      }

      onResize(e) {
        const img = this.cropImage;
        const dx = e.clientX - this.dragStart.x;
        const dy = e.clientY - this.dragStart.y;

        let newWidth = this.cropData.width;
        let newHeight = this.cropData.height;
        let newX = this.cropData.x;
        let newY = this.cropData.y;

        if (this.resizeHandle === 'se') {
          newWidth = this.cropData.width + dx;
          newHeight = newWidth / this.aspectRatio;
        } else if (this.resizeHandle === 'sw') {
          newWidth = this.cropData.width - dx;
          newHeight = newWidth / this.aspectRatio;
          newX = this.cropData.x + dx;
        } else if (this.resizeHandle === 'ne') {
          newWidth = this.cropData.width + dx;
          newHeight = newWidth / this.aspectRatio;
          newY = this.cropData.y - (newHeight - this.cropData.height);
        } else if (this.resizeHandle === 'nw') {
          newWidth = this.cropData.width - dx;
          newHeight = newWidth / this.aspectRatio;
          newX = this.cropData.x + dx;
          newY = this.cropData.y - (newHeight - this.cropData.height);
        }

        if (newWidth > 50 && newHeight > 50 &&
            newX >= 0 && newY >= 0 &&
            newX + newWidth <= img.clientWidth &&
            newY + newHeight <= img.clientHeight) {
          this.cropData = { x: newX, y: newY, width: newWidth, height: newHeight };
          this.dragStart = { x: e.clientX, y: e.clientY };
          this.updateCropOverlay();
        }
      }

      applyCrop() {
        const img = this.cropImage;
        const canvas = document.createElement('canvas');
        const scaleX = img.naturalWidth / img.clientWidth;
        const scaleY = img.naturalHeight / img.clientHeight;

        canvas.width = this.cropData.width * scaleX;
        canvas.height = this.cropData.height * scaleY;

        const ctx = canvas.getContext('2d');
        ctx.drawImage(
          img,
          this.cropData.x * scaleX,
          this.cropData.y * scaleY,
          canvas.width,
          canvas.height,
          0,
          0,
          canvas.width,
          canvas.height
        );

        this.croppedImage = canvas.toDataURL('image/jpeg', 0.9);
        this.showStep('form');
      }

      showStep(step) {
        this.querySelectorAll('.ai-image-upload-tool__step-{{ ai_gen_id }}').forEach(el => {
          el.classList.remove('active');
        });

        if (step === 'upload') {
          this.querySelector('.ai-image-upload-tool__step-upload-{{ ai_gen_id }}').classList.add('active');
        } else if (step === 'crop') {
          this.querySelector('.ai-image-upload-tool__step-crop-{{ ai_gen_id }}').classList.add('active');
        } else if (step === 'form') {
          this.previewImage.src = this.croppedImage;
          this.imageDataInput.value = this.croppedImage;
          this.imageLinkInput.value = 'Image stored in browser (cannot be uploaded to server)';
          this.querySelector('.ai-image-upload-tool__step-form-{{ ai_gen_id }}').classList.add('active');
        } else if (step === 'success') {
          this.querySelector('.ai-image-upload-tool__step-success-{{ ai_gen_id }}').classList.add('active');
        }

        this.currentStep = step;
      }

      handleSubmit() {
        this.showStep('success');
      }

      reset() {
        this.fileInput.value = '';
        this.originalImage = null;
        this.croppedImage = null;
        this.form.reset();
        this.showStep('upload');
      }
    }

    customElements.define('image-upload-tool-{{ ai_gen_id }}', ImageUploadTool{{ ai_gen_id }});
  })();
</script>

