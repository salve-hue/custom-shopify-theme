{% doc %}
  @prompt
    A text box with a red background and the text: Clear stitched playmats should be back in stock by next week. I apologize for the inconvenience!
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
    max-width: 100%;
  }

  .ai-announcement-box__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.5;
    margin: 0;
  }
{% endstyle %}

<div class="ai-announcement-box-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-announcement-box__text-{{ ai_gen_id }}">
    {{ block.settings.message }}
  </div>
</div>

{% schema %}
{
  "name": "Announcement box",
  "settings": [
    {
      "type": "richtext",
      "id": "message",
      "label": "Message",
      "default": "<p>Clear stitched playmats should be back in stock by next week. I apologize for the inconvenience!</p>"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ff0000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Announcement box"
    }
  ]
}
{% endschema %}
