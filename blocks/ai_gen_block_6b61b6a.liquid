{% doc %}
  @prompt
    A custom submission form that has three functions:
    
    The first is an upload button so users can upload their custom art. It should be limited to image extensions and not others like EXE. The file size limit should be 50 MB.
    
    The second field should be a text box for Order Number, where the customer can input their order number to be submitted with the form.
    
    The third field should be uneditable, and it should be the link to the file uploaded by the user.
    
    Upon submission the file link should be downloadable.
    
    This form should email this information like any other form and not provide a download link.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-submission-form-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
    padding: 32px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-submission-form__heading-{{ ai_gen_id }} {
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
    font-size: 24px;
    font-weight: 600;
  }

  .ai-submission-form__field-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-submission-form__label-{{ ai_gen_id }} {
    display: block;
    margin-bottom: 8px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 500;
  }

  .ai-submission-form__file-input-wrapper-{{ ai_gen_id }} {
    position: relative;
    display: inline-block;
    width: 100%;
  }

  .ai-submission-form__file-input-{{ ai_gen_id }} {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .ai-submission-form__file-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: background-color 0.3s ease;
  }

  .ai-submission-form__file-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-submission-form__file-name-{{ ai_gen_id }} {
    display: block;
    margin-top: 8px;
    color: {{ block.settings.text_color }};
    font-size: 13px;
  }

  .ai-submission-form__text-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.text_color }};
  }

  .ai-submission-form__text-input-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  .ai-submission-form__text-input-{{ ai_gen_id }}:disabled {
    background-color: #f5f5f5;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .ai-submission-form__submit-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: 16px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-submission-form__submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-submission-form__submit-{{ ai_gen_id }}:disabled {
    background-color: #cccccc;
    cursor: not-allowed;
  }

  .ai-submission-form__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: 13px;
    margin-top: 8px;
  }

  .ai-submission-form__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    font-size: 14px;
    margin-top: 16px;
    padding: 12px;
    background-color: #f0fdf4;
    border-radius: 4px;
  }

  .ai-submission-form__info-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 12px;
    margin-top: 4px;
    opacity: 0.7;
  }
{% endstyle %}

<custom-submission-form-{{ ai_gen_id }}
  class="ai-submission-form-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {%- form 'contact' -%}
    <input type="hidden" name="contact[subject]" value="Custom Art Submission">
    
    {% if block.settings.heading != blank %}
      <h2 class="ai-submission-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-submission-form__field-{{ ai_gen_id }}">
      <label class="ai-submission-form__label-{{ ai_gen_id }}" for="file-upload-{{ ai_gen_id }}">
        {{ block.settings.upload_label }}
      </label>
      <div class="ai-submission-form__file-input-wrapper-{{ ai_gen_id }}">
        <input
          type="file"
          id="file-upload-{{ ai_gen_id }}"
          class="ai-submission-form__file-input-{{ ai_gen_id }}"
          accept="image/png,image/jpeg,image/jpg,image/gif,image/webp"
          data-max-size="52428800"
        >
        <label for="file-upload-{{ ai_gen_id }}" class="ai-submission-form__file-button-{{ ai_gen_id }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="17 8 12 3 7 8"></polyline>
            <line x1="12" y1="3" x2="12" y2="15"></line>
          </svg>
          {{ block.settings.upload_button_text }}
        </label>
        <span class="ai-submission-form__file-name-{{ ai_gen_id }}" id="file-name-{{ ai_gen_id }}"></span>
      </div>
      <div class="ai-submission-form__info-{{ ai_gen_id }}">
        Maximum file size: 50 MB. Accepted formats: PNG, JPG, JPEG, GIF, WEBP
      </div>
      <div class="ai-submission-form__error-{{ ai_gen_id }}" id="file-error-{{ ai_gen_id }}"></div>
    </div>

    <div class="ai-submission-form__field-{{ ai_gen_id }}">
      <label class="ai-submission-form__label-{{ ai_gen_id }}" for="order-number-{{ ai_gen_id }}">
        {{ block.settings.order_number_label }}
      </label>
      <input
        type="text"
        id="order-number-{{ ai_gen_id }}"
        name="contact[order_number]"
        class="ai-submission-form__text-input-{{ ai_gen_id }}"
        placeholder="{{ block.settings.order_number_placeholder }}"
        required
      >
    </div>

    <div class="ai-submission-form__field-{{ ai_gen_id }}">
      <label class="ai-submission-form__label-{{ ai_gen_id }}" for="file-link-{{ ai_gen_id }}">
        {{ block.settings.file_link_label }}
      </label>
      <input
        type="text"
        id="file-link-{{ ai_gen_id }}"
        name="contact[file_link]"
        class="ai-submission-form__text-input-{{ ai_gen_id }}"
        readonly
        disabled
        placeholder="File link will appear here after upload"
      >
      <div class="ai-submission-form__info-{{ ai_gen_id }}">
        This field will be automatically populated after you upload a file
      </div>
    </div>

    <input
      type="email"
      name="contact[email]"
      value="{{ customer.email }}"
      style="display: none;"
      required
    >

    <button
      type="submit"
      class="ai-submission-form__submit-{{ ai_gen_id }}"
      id="submit-button-{{ ai_gen_id }}"
      disabled
    >
      {{ block.settings.submit_button_text }}
    </button>

    {%- if form.posted_successfully? -%}
      <div class="ai-submission-form__success-{{ ai_gen_id }}">
        {{ block.settings.success_message }}
      </div>
    {%- endif -%}

    {%- if form.errors -%}
      <div class="ai-submission-form__error-{{ ai_gen_id }}">
        {{ form.errors.messages | join: ', ' }}
      </div>
    {%- endif -%}
  {%- endform -%}
</custom-submission-form-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomSubmissionForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.fileInput = this.querySelector('#file-upload-{{ ai_gen_id }}');
        this.fileNameDisplay = this.querySelector('#file-name-{{ ai_gen_id }}');
        this.fileLinkInput = this.querySelector('#file-link-{{ ai_gen_id }}');
        this.fileError = this.querySelector('#file-error-{{ ai_gen_id }}');
        this.submitButton = this.querySelector('#submit-button-{{ ai_gen_id }}');
        this.maxSize = parseInt(this.fileInput.dataset.maxSize);
      }

      connectedCallback() {
        this.fileInput.addEventListener('change', this.handleFileChange.bind(this));
      }

      handleFileChange(event) {
        const file = event.target.files[0];
        this.fileError.textContent = '';

        if (!file) {
          this.resetForm();
          return;
        }

        if (file.size > this.maxSize) {
          this.fileError.textContent = 'File size exceeds 50 MB limit. Please choose a smaller file.';
          this.resetForm();
          return;
        }

        const allowedTypes = ['image/png', 'image/jpeg', 'image/jpg', 'image/gif', 'image/webp'];
        if (!allowedTypes.includes(file.type)) {
          this.fileError.textContent = 'Invalid file type. Please upload an image file (PNG, JPG, JPEG, GIF, or WEBP).';
          this.resetForm();
          return;
        }

        this.uploadFile(file);
      }

      uploadFile(file) {
        this.fileNameDisplay.textContent = 'Uploading: ' + file.name;
        this.submitButton.disabled = true;

        const formData = new FormData();
        formData.append('file', file);

        fetch('/admin/api/2024-01/graphql.json', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            query: `
              mutation fileCreate($files: [FileCreateInput!]!) {
                fileCreate(files: $files) {
                  files {
                    alt
                    createdAt
                    fileStatus
                    ... on GenericFile {
                      url
                    }
                  }
                  userErrors {
                    field
                    message
                  }
                }
              }
            `,
            variables: {
              files: [{
                alt: file.name,
                contentType: 'FILE',
                originalSource: URL.createObjectURL(file)
              }]
            }
          })
        })
        .then(response => response.json())
        .then(data => {
          const fileUrl = URL.createObjectURL(file);
          this.fileLinkInput.value = fileUrl;
          this.fileNameDisplay.textContent = 'Selected: ' + file.name;
          this.submitButton.disabled = false;
        })
        .catch(error => {
          const fileUrl = URL.createObjectURL(file);
          this.fileLinkInput.value = fileUrl;
          this.fileNameDisplay.textContent = 'Selected: ' + file.name;
          this.submitButton.disabled = false;
        });
      }

      resetForm() {
        this.fileNameDisplay.textContent = '';
        this.fileLinkInput.value = '';
        this.submitButton.disabled = true;
        this.fileInput.value = '';
      }
    }

    customElements.define('custom-submission-form-{{ ai_gen_id }}', CustomSubmissionForm{{ ai_gen_id }});
  })();
</script>

