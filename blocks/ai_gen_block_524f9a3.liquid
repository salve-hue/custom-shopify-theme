{% doc %}
  @prompt
    Write a subscription widget with options to customize how it looks, colors, size of lines, rounding corners. IT should tie into subscriptions for the product page it is currently enabled., Allow the customization of the discount to either a percent or flat cost.
    It should integrate with the existing Shopify Subscriptions app and use it, but I want this custom front end.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-subscription-widget-{{ ai_gen_id }} {
    padding: {{ block.settings.widget_padding }}px;
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    margin: {{ block.settings.widget_margin }}px 0;
  }

  .ai-subscription-widget__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
    font-weight: 600;
  }

  .ai-subscription-widget__options-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-subscription-widget__option-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: {{ block.settings.option_padding }}px;
    border: {{ block.settings.option_border_width }}px solid {{ block.settings.option_border_color }};
    border-radius: {{ block.settings.option_border_radius }}px;
    cursor: pointer;
    transition: all 0.2s ease;
    background-color: {{ block.settings.option_background }};
  }

  .ai-subscription-widget__option-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.option_hover_border_color }};
    background-color: {{ block.settings.option_hover_background }};
  }

  .ai-subscription-widget__option-{{ ai_gen_id }}.selected {
    border-color: {{ block.settings.selected_border_color }};
    background-color: {{ block.settings.selected_background }};
  }

  .ai-subscription-widget__radio-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    border: 2px solid {{ block.settings.radio_border_color }};
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
    margin-top: 2px;
  }

  .ai-subscription-widget__option-{{ ai_gen_id }}.selected .ai-subscription-widget__radio-{{ ai_gen_id }} {
    border-color: {{ block.settings.radio_selected_color }};
  }

  .ai-subscription-widget__option-{{ ai_gen_id }}.selected .ai-subscription-widget__radio-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background-color: {{ block.settings.radio_selected_color }};
    border-radius: 50%;
  }

  .ai-subscription-widget__option-content-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-subscription-widget__option-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.option_label_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    margin: 0 0 4px 0;
    display: block;
  }

  .ai-subscription-widget__option-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.option_description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  .ai-subscription-widget__discount-badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 4px 8px;
    background-color: {{ block.settings.discount_badge_background }};
    color: {{ block.settings.discount_badge_text }};
    border-radius: {{ block.settings.discount_badge_radius }}px;
    font-size: {{ block.settings.discount_badge_size }}px;
    font-weight: 600;
    margin-left: 8px;
  }

  .ai-subscription-widget__frequency-{{ ai_gen_id }} {
    margin-top: 16px;
  }

  .ai-subscription-widget__frequency-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.option_label_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    margin: 0 0 8px 0;
    display: block;
  }

  .ai-subscription-widget__frequency-select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px;
    border: {{ block.settings.option_border_width }}px solid {{ block.settings.option_border_color }};
    border-radius: {{ block.settings.option_border_radius }}px;
    background-color: {{ block.settings.option_background }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.option_description_size }}px;
  }

  .ai-subscription-widget__frequency-select-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.selected_border_color }};
  }

  .ai-subscription-widget__hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-subscription-widget-{{ ai_gen_id }} {
      padding: {{ block.settings.widget_padding | times: 0.75 }}px;
    }

    .ai-subscription-widget__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<subscription-widget-{{ ai_gen_id }}
  class="ai-subscription-widget-{{ ai_gen_id }}"
  data-product-id="{{ product.id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.widget_title != blank %}
    <h3 class="ai-subscription-widget__title-{{ ai_gen_id }}">{{ block.settings.widget_title }}</h3>
  {% endif %}

  <div class="ai-subscription-widget__options-{{ ai_gen_id }}">
    <div
      class="ai-subscription-widget__option-{{ ai_gen_id }} {% if block.settings.default_selection == 'onetime' %}selected{% endif %}"
      data-option="onetime"
    >
      <div class="ai-subscription-widget__radio-{{ ai_gen_id }}"></div>
      <div class="ai-subscription-widget__option-content-{{ ai_gen_id }}">
        <label class="ai-subscription-widget__option-label-{{ ai_gen_id }}">
          {{ block.settings.onetime_label }}
        </label>
        {% if block.settings.onetime_description != blank %}
          <p class="ai-subscription-widget__option-description-{{ ai_gen_id }}">
            {{ block.settings.onetime_description }}
          </p>
        {% endif %}
      </div>
    </div>

    <div
      class="ai-subscription-widget__option-{{ ai_gen_id }} {% if block.settings.default_selection == 'subscription' %}selected{% endif %}"
      data-option="subscription"
    >
      <div class="ai-subscription-widget__radio-{{ ai_gen_id }}"></div>
      <div class="ai-subscription-widget__option-content-{{ ai_gen_id }}">
        <label class="ai-subscription-widget__option-label-{{ ai_gen_id }}">
          {{ block.settings.subscription_label }}
          {% if block.settings.show_discount_badge %}
            <span class="ai-subscription-widget__discount-badge-{{ ai_gen_id }}">
              {% if block.settings.discount_type == 'percentage' %}
                {{ block.settings.discount_value }}% off
              {% else %}
                ${{ block.settings.discount_value }} off
              {% endif %}
            </span>
          {% endif %}
        </label>
        {% if block.settings.subscription_description != blank %}
          <p class="ai-subscription-widget__option-description-{{ ai_gen_id }}">
            {{ block.settings.subscription_description }}
          </p>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="ai-subscription-widget__frequency-{{ ai_gen_id }} {% if block.settings.default_selection == 'onetime' %}ai-subscription-widget__hidden-{{ ai_gen_id }}{% endif %}">
    <label class="ai-subscription-widget__frequency-label-{{ ai_gen_id }}">
      {{ block.settings.frequency_label }}
    </label>
    <select class="ai-subscription-widget__frequency-select-{{ ai_gen_id }}" name="selling_plan">
      <option value="">Select delivery frequency</option>
      {% for group in product.selling_plan_groups %}
        {% for plan in group.selling_plans %}
          <option value="{{ plan.id }}" {% if forloop.first %}selected{% endif %}>
            {{ plan.name }}
          </option>
        {% endfor %}
      {% endfor %}
    </select>
  </div>

  <input type="hidden" name="purchase_type" value="{{ block.settings.default_selection }}">
</subscription-widget-{{ ai_gen_id }}>

<script>
  (function() {
    class SubscriptionWidget{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.options = this.querySelectorAll('.ai-subscription-widget__option-{{ ai_gen_id }}');
        this.frequencyContainer = this.querySelector('.ai-subscription-widget__frequency-{{ ai_gen_id }}');
        this.frequencySelect = this.querySelector('.ai-subscription-widget__frequency-select-{{ ai_gen_id }}');
        this.purchaseTypeInput = this.querySelector('input[name="purchase_type"]');
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.options.forEach((option) => {
          option.addEventListener('click', () => {
            this.handleOptionClick(option);
          });
        });

        this.frequencySelect.addEventListener('change', () => {
          this.updateProductForm();
        });
      }

      handleOptionClick(selectedOption) {
        this.options.forEach((option) => {
          option.classList.remove('selected');
        });

        selectedOption.classList.add('selected');

        const optionType = selectedOption.getAttribute('data-option');
        this.purchaseTypeInput.value = optionType;

        if (optionType === 'subscription') {
          this.frequencyContainer.classList.remove('ai-subscription-widget__hidden-{{ ai_gen_id }}');
        } else {
          this.frequencyContainer.classList.add('ai-subscription-widget__hidden-{{ ai_gen_id }}');
        }

        this.updateProductForm();
      }

      updateProductForm() {
        const productForm = document.querySelector('form[action*="/cart/add"]');
        if (!productForm) return;

        const purchaseType = this.purchaseTypeInput.value;
        let existingSellingPlanInput = productForm.querySelector('input[name="selling_plan"]');

        if (purchaseType === 'subscription') {
          const selectedPlanId = this.frequencySelect.value;

          if (selectedPlanId) {
            if (existingSellingPlanInput) {
              existingSellingPlanInput.value = selectedPlanId;
            } else {
              existingSellingPlanInput = document.createElement('input');
              existingSellingPlanInput.type = 'hidden';
              existingSellingPlanInput.name = 'selling_plan';
              existingSellingPlanInput.value = selectedPlanId;
              productForm.appendChild(existingSellingPlanInput);
            }
          }
        } else {
          if (existingSellingPlanInput) {
            existingSellingPlanInput.remove();
          }
        }

        const event = new CustomEvent('subscription-widget:change', {
          detail: {
            purchaseType: purchaseType,
            sellingPlanId: purchaseType === 'subscription' ? this.frequencySelect.value : null
          },
          bubbles: true
        });
        this.dispatchEvent(event);
      }
    }

    customElements.define('subscription-widget-{{ ai_gen_id }}', SubscriptionWidget{{ ai_gen_id }});
  })();
</script>

