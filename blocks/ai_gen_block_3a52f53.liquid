      <div class="ai-discount-calculator__input-group-{{ ai_gen_id }}">
        <label for="quantity-input-{{ ai_gen_id }}" class="ai-discount-calculator__label-{{ ai_gen_id }}">
          Number of playmats
        </label>
        <input
          type="number"
