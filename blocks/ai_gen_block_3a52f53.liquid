          <div class="ai-discount-calculator__result-label-{{ ai_gen_id }}">Unit price</div>
          <div class="ai-discount-calculator__result-value-{{ ai_gen_id }}" data-unit-price>$0.00</div>
        </div>
        <div class="ai-discount-calculator__result-item-{{ ai_gen_id }}">
          <div class="ai-discount-calculator__result-label-{{ ai_gen_id }}">Savings</div>
          <div class="ai-discount-calculator__result-value-{{ ai_gen_id }}" data-savings>$0.00</div>
        </div>
        <div class="ai-discount-calculator__result-item-{{ ai_gen_id }}">
          <div class="ai-discount-calculator__result-label-{{ ai_gen_id }}">Total</div>
          <div class="ai-discount-calculator__result-value-{{ ai_gen_id }} ai-discount-calculator__result-value--large-{{ ai_gen_id }}" data-total>$0.00</div>
        </div>
      </div>
    </div>

    <div class="ai-discount-calculator__bulk-message-{{ ai_gen_id }}">
      <p class="ai-discount-calculator__bulk-text-{{ ai_gen_id }}">
        {{ block.settings.bulk_message }}
      </p>
      {% if block.settings.bulk_form_link != blank %}
        <a
          href="{{ block.settings.bulk_form_link }}"
          class="ai-discount-calculator__bulk-button-{{ ai_gen_id }}"
        >
          {{ block.settings.bulk_button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</playmat-discount-calculator-{{ ai_gen_id }}>

<script>
  (function() {
    class PlaymatDiscountCalculator{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.discountTiers = [
          { quantity: 5, discount: 0.05 },
          { quantity: 10, discount: 0.10 },
          { quantity: 15, discount: 0.15 },
          { quantity: 20, discount: 0.20 },
          { quantity: 25, discount: 0.30 },
          { quantity: 30, discount: 0.40 }
        ];
      }

      connectedCallback() {
        this.priceInput = this.querySelector('#price-input-{{ ai_gen_id }}');
        this.quantityInput = this.querySelector('#quantity-input-{{ ai_gen_id }}');
        this.resultContainer = this.querySelector('.ai-discount-calculator__result-{{ ai_gen_id }}');
        this.bulkMessage = this.querySelector('.ai-discount-calculator__bulk-message-{{ ai_gen_id }}');
        this.quantityDisplay = this.querySelector('[data-quantity]');
        this.discountDisplay = this.querySelector('[data-discount]');
        this.unitPriceDisplay = this.querySelector('[data-unit-price]');
        this.savingsDisplay = this.querySelector('[data-savings]');
        this.totalDisplay = this.querySelector('[data-total]');

        this.priceInput.addEventListener('input', () => this.calculate());
        this.quantityInput.addEventListener('input', () => this.calculate());
      }

      calculate() {
        const basePrice = parseFloat(this.priceInput.value) || 0;
        const quantity = parseInt(this.quantityInput.value) || 0;

        if (quantity === 0 || basePrice === 0) {
          this.resultContainer.classList.remove('active');
          this.bulkMessage.classList.remove('active');
          return;
        }

        if (quantity >= 50) {
          this.resultContainer.classList.remove('active');
          this.bulkMessage.classList.add('active');
          return;
        }

        this.bulkMessage.classList.remove('active');
        this.resultContainer.classList.add('active');

        const discountRate = this.getDiscountRate(quantity);
        const unitPrice = basePrice * (1 - discountRate);
        const totalPrice = unitPrice * quantity;
        const originalTotal = basePrice * quantity;
        const savings = originalTotal - totalPrice;

        this.quantityDisplay.textContent = quantity;
        this.discountDisplay.textContent = (discountRate * 100) + '%';
        this.unitPriceDisplay.textContent = '$' + unitPrice.toFixed(2);
        this.savingsDisplay.textContent = '$' + savings.toFixed(2);
        this.totalDisplay.textContent = '$' + totalPrice.toFixed(2);
      }

      getDiscountRate(quantity) {
        let discount = 0;
        for (let i = this.discountTiers.length - 1; i >= 0; i--) {
          if (quantity >= this.discountTiers[i].quantity) {
            discount = this.discountTiers[i].discount;
            break;
          }
        }
        return discount;
      }
    }

    customElements.define('playmat-discount-calculator-{{ ai_gen_id }}', PlaymatDiscountCalculator{{ ai_gen_id }});
  })();
</script>

