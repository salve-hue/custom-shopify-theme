{% doc %}
  @prompt
    Create a custom block for text that has full word processing capabilities, like fonts, colors, sizes, formatting, and everything. I need all options available so I can make text look nice and readable.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rich-text-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-rich-text-content-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
    font-style: {{ block.settings.font_family.style }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}em;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_align }};
    {% if block.settings.text_transform != 'none' %}
      text-transform: {{ block.settings.text_transform }};
    {% endif %}
    {% if block.settings.font_style == 'italic' %}
      font-style: italic;
    {% endif %}
    {% if block.settings.text_decoration != 'none' %}
      text-decoration: {{ block.settings.text_decoration }};
    {% endif %}
  }

  .ai-rich-text-content-{{ ai_gen_id }} h1,
  .ai-rich-text-content-{{ ai_gen_id }} h2,
  .ai-rich-text-content-{{ ai_gen_id }} h3,
  .ai-rich-text-content-{{ ai_gen_id }} h4,
  .ai-rich-text-content-{{ ai_gen_id }} h5,
  .ai-rich-text-content-{{ ai_gen_id }} h6 {
    color: {{ block.settings.heading_color }};
    margin-top: {{ block.settings.heading_spacing }}px;
    margin-bottom: {{ block.settings.heading_spacing | divided_by: 2 }}px;
  }

  .ai-rich-text-content-{{ ai_gen_id }} p {
    margin-bottom: {{ block.settings.paragraph_spacing }}px;
  }

  .ai-rich-text-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: {{ block.settings.link_decoration }};
  }

  .ai-rich-text-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
    {% if block.settings.link_hover_decoration != 'none' %}
      text-decoration: {{ block.settings.link_hover_decoration }};
    {% endif %}
  }

  .ai-rich-text-content-{{ ai_gen_id }} ul,
  .ai-rich-text-content-{{ ai_gen_id }} ol {
    margin-left: {{ block.settings.list_indent }}px;
    margin-bottom: {{ block.settings.paragraph_spacing }}px;
  }

  .ai-rich-text-content-{{ ai_gen_id }} li {
    margin-bottom: {{ block.settings.list_item_spacing }}px;
  }

  .ai-rich-text-content-{{ ai_gen_id }} blockquote {
    border-left: {{ block.settings.blockquote_border_width }}px solid {{ block.settings.blockquote_border_color }};
    padding-left: {{ block.settings.blockquote_padding }}px;
    margin: {{ block.settings.paragraph_spacing }}px 0;
    font-style: {{ block.settings.blockquote_style }};
    color: {{ block.settings.blockquote_color }};
  }

  .ai-rich-text-content-{{ ai_gen_id }} strong,
  .ai-rich-text-content-{{ ai_gen_id }} b {
    font-weight: {{ block.settings.bold_weight }};
  }

  .ai-rich-text-content-{{ ai_gen_id }} em,
  .ai-rich-text-content-{{ ai_gen_id }} i {
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-rich-text-block-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-rich-text-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-rich-text-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-rich-text-content-{{ ai_gen_id }}">
    {% if block.settings.content != blank %}
      {{ block.settings.content }}
    {% else %}
      <p>Add your rich text content here. Use the editor to format your text with headings, paragraphs, lists, and more.</p>
    {% endif %}
  </div>
</div>

