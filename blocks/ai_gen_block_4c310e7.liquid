{% doc %}
  @prompt
    Make a simple contact for with three fields: Name, Email, and Message. I want everything to be editable so I can customize it. I want it to fit horizontally if possible or allow me to make it fit horizontally on a desktop view and responsive for mobile view., Add the option for a subheading.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-contact-form__wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-contact-form__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {% if block.settings.subheading != blank %}8px{% else %}{{ block.settings.spacing }}px{% endif %} 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.spacing }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-contact-form__fields-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.spacing }}px;
    margin-bottom: {{ block.settings.spacing }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-contact-form__fields-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    }

    .ai-contact-form__field--message-{{ ai_gen_id }} {
      grid-column: 1 / -1;
    }
  }

  .ai-contact-form__label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    margin-bottom: 8px;
    font-weight: 500;
  }

  .ai-contact-form__input-{{ ai_gen_id }},
  .ai-contact-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    font-size: {{ block.settings.input_text_size }}px;
    font-family: inherit;
  }

  .ai-contact-form__input-{{ ai_gen_id }}:focus,
  .ai-contact-form__textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-contact-form__textarea-{{ ai_gen_id }} {
    min-height: {{ block.settings.message_height }}px;
    resize: vertical;
  }

  .ai-contact-form__button-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.button_alignment }};
  }

  .ai-contact-form__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-contact-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-contact-form__message-{{ ai_gen_id }} {
    margin-top: {{ block.settings.spacing }}px;
    padding: 12px 16px;
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_text_size }}px;
  }

  .ai-contact-form__message--success-{{ ai_gen_id }} {
    background-color: {{ block.settings.success_background }};
    color: {{ block.settings.success_text_color }};
  }

  .ai-contact-form__message--error-{{ ai_gen_id }} {
    background-color: {{ block.settings.error_background }};
    color: {{ block.settings.error_text_color }};
  }
{% endstyle %}

<contact-form-{{ ai_gen_id }} class="ai-contact-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-form__wrapper-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-contact-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <p class="ai-contact-form__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
    {% endif %}

    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div class="ai-contact-form__message-{{ ai_gen_id }} ai-contact-form__message--success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="ai-contact-form__message-{{ ai_gen_id }} ai-contact-form__message--error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
          {{ form.errors.messages | first }}
        </div>
      {% endif %}

      <div class="ai-contact-form__fields-{{ ai_gen_id }}">
        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-name-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.name_label }}
          </label>
          <input
            type="text"
            id="ai-contact-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.name_placeholder }}"
            value="{% if form.name %}{{ form.name }}{% endif %}"
            required
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }}">
          <label for="ai-contact-email-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.email_label }}
          </label>
          <input
            type="email"
            id="ai-contact-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-contact-form__input-{{ ai_gen_id }}"
            placeholder="{{ block.settings.email_placeholder }}"
            value="{% if form.email %}{{ form.email }}{% endif %}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-contact-form-success-{{ ai_gen_id }}"
            {% endif %}
            required
          >
        </div>

        <div class="ai-contact-form__field-{{ ai_gen_id }} ai-contact-form__field--message-{{ ai_gen_id }}">
          <label for="ai-contact-message-{{ ai_gen_id }}" class="ai-contact-form__label-{{ ai_gen_id }}">
            {{ block.settings.message_label }}
          </label>
          <textarea
            id="ai-contact-message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-contact-form__textarea-{{ ai_gen_id }}"
            placeholder="{{ block.settings.message_placeholder }}"
            required
          >{% if form.body %}{{ form.body }}{% endif %}</textarea>
        </div>
      </div>

      <div class="ai-contact-form__button-wrapper-{{ ai_gen_id }}">
        <button type="submit" class="ai-contact-form__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>
      </div>
    {% endform %}
  </div>
</contact-form-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        const successMessage = this.querySelector('.ai-contact-form__message--success-{{ ai_gen_id }}');
        
        if (successMessage) {
          form.reset();
        }
      }
    }

    customElements.define('contact-form-{{ ai_gen_id }}', ContactForm{{ ai_gen_id }});
  })();
</script>

