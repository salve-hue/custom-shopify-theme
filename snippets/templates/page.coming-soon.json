{"sections":{"main":{"type":"main-page","blocks":{"heading":{"type":"text","name":"Title","settings":{"text":"<h1>Default Page<\/h1>","width":"100%","max_width":"normal","alignment":"center","type_preset":"h2","font":"var(--font-primary--family)","font_size":"","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"page-content":{"type":"page-content","disabled":true,"settings":{},"blocks":{}},"text_NKEG7g":{"type":"text","name":"t:names.text","settings":{"text":"<p>Insert Text Here<\/p>","width":"100%","max_width":"none","alignment":"center","type_preset":"h5","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["heading","page-content","text_NKEG7g"],"disabled":true,"settings":{"content_direction":"column","gap":32,"color_scheme":"","padding-block-start":40,"padding-block-end":40}},"custom_liquid_GMq88c":{"type":"custom-liquid","name":"t:names.custom_liquid","settings":{"custom_liquid":"<link href=\"https:\/\/fonts.googleapis.com\/css2?family=Rubik:wght@400;500;700&family=Bangers&family=Press+Start+2P&family=Permanent+Marker&display=swap\" rel=\"stylesheet\">\n\n<script>\n    const SIZE_DB = {\n        \"standard\": { label: \"Standard (24\\\"x14\\\")\", w: 24.5, h: 14.5, \n            variants: [{ id: \"47402042753283\", name: \"Clear Stitched Edges\" }, { id: \"47402042786051\", name: \"Black Stitched Edges\" }, { id: \"47402042818819\", name: \"Unstitched Edges\" }] \n        },\n        \"extended\": { label: \"Extended (28\\\"x14\\\")\", w: 28.5, h: 14.5, \n            variants: [{ id: \"8712290107651\", name: \"Clear Stitched Edges\" }] \n        }\n    };\n\n    const LAYOUT_RAW = [\n        { game: \"Magic: the Gathering\", format: \"60-card\", size: \"Standard\", hand: \"Left\", url: \"https:\/\/cdn.shopify.com\/s\/files\/1\/0704\/4107\/4947\/files\/60-Card_New_Player_Standard_Left_Handed.png?v=1771523546\" },\n        { game: \"Magic: the Gathering\", format: \"60-card\", size: \"Standard\", hand: \"Right\", url: \"https:\/\/cdn.shopify.com\/s\/files\/1\/0704\/4107\/4947\/files\/60-Card_New_Player_Standard_Right_Handed.png?v=1771523546\" },\n        { game: \"Magic: the Gathering\", format: \"60-card\", size: \"Extended\", hand: \"Left\", url: \"https:\/\/cdn.shopify.com\/s\/files\/1\/0704\/4107\/4947\/files\/60-Card_New_Player_Extended_Left_Handed.png?v=1771523546\" },\n        { game: \"Magic: the Gathering\", format: \"60-card\", size: \"Extended\", hand: \"Right\", url: \"https:\/\/cdn.shopify.com\/s\/files\/1\/0704\/4107\/4947\/files\/60-Card_New_Player_Extended_Right_Handed.png?v=1771523546\" },\n        { game: \"Magic: the Gathering\", format: \"Commander\", size: \"Standard\", hand: \"Left\", url: \"https:\/\/cdn.shopify.com\/s\/files\/1\/0704\/4107\/4947\/files\/Commander_New_Player_Standard_Left_Handed.png?v=1771523546\" },\n        { game: \"Magic: the Gathering\", format: \"Commander\", size: \"Standard\", hand: \"Right\", url: \"https:\/\/cdn.shopify.com\/s\/files\/1\/0704\/4107\/4947\/files\/Commander_New_Player_Standard_Right_Handed.png?v=1771523546\" },\n        { game: \"Magic: the Gathering\", format: \"Commander\", size: \"Extended\", hand: \"Left\", url: \"https:\/\/cdn.shopify.com\/s\/files\/1\/0704\/4107\/4947\/files\/Commander_New_Player_Extended_Left_Handed.png?v=1771523546\" },\n        { game: \"Magic: the Gathering\", format: \"Commander\", size: \"Extended\", hand: \"Right\", url: \"https:\/\/cdn.shopify.com\/s\/files\/1\/0704\/4107\/4947\/files\/Commander_New_Player_Extended_Right_Handed.png?v=1771523546\" }\n    ];\n<\/script>\n\n<style>\n    :root { --brand: #DF5918; --green: #28a745; --upload-blue: #02B6FA; --dark: #1a1a1a; }\n    #playmat-tool-root * { font-family: 'Rubik', sans-serif !important; box-sizing: border-box; }\n    .sidebar-header { background: #333; padding: 15px; border-bottom: 1px solid #444; }\n    .action-btn { width: 100%; border: none; font-weight: 700; cursor: pointer; color: #fff; transition: opacity 0.2s; }\n    .btn-upload { background: var(--upload-blue); border-radius: 6px; padding: 15px; font-size: 14px; }\n    .btn-reset { background: #555; font-size: 11px; padding: 8px; border-radius: 4px; }\n    .acc-btn { width: 100%; padding: 16px; background: #222; color: white; border: none; border-bottom: 1px solid #333; text-align: left; cursor: pointer; font-size: 13px; font-weight: bold; display: flex; justify-content: space-between; }\n    .acc-content { padding: 20px; display: none; background: #2a2a2a; color: #fff; border-bottom: 1px solid #444; }\n    .ui-select { width: 100%; padding: 10px; background: #444; color: #fff; border: 1px solid #555; border-radius: 4px; margin-bottom: 10px; font-size: 12px; }\n    .slider-row { margin-top: 12px; }\n    .slider-row label { font-size: 10px; color: #aaa; display: block; margin-bottom: 4px; }\n    .hidden-field { display: none; }\n    #canvas-wrapper { position: relative; line-height: 0; box-shadow: 0 0 40px rgba(0,0,0,0.5); }\n    #layout-mask-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; display: none; z-index: 10; mask-size: 100% 100%; -webkit-mask-size: 100% 100%; }\n<\/style>\n\n<div id=\"playmat-tool-root\">\n    <div style=\"display: flex; background: var(--dark); min-height: 800px;\">\n        <div id=\"sidebar\" style=\"width: 300px; border-right: 1px solid #444; overflow-y: auto;\">\n            \n            <div class=\"sidebar-header\">\n                <button class=\"action-btn btn-reset\" onclick=\"location.reload()\">RESTART DESIGN<\/button>\n            <\/div>\n\n            <button class=\"acc-btn\" onclick=\"window.toggleAcc('acc-size')\">SIZE <span>▼<\/span><\/button>\n            <div id=\"acc-size\" class=\"acc-content\" style=\"display:block;\">\n                <label style=\"font-size:10px; color:#aaa;\">Choose Mat Size<\/label>\n                <select id=\"size-sel\" class=\"ui-select\" onchange=\"window.changeSize()\"><option value=\"\">-- Select Size --<\/option><\/select>\n                \n                <div style=\"margin-top:15px;\">\n                    <button class=\"action-btn btn-upload\" onclick=\"document.getElementById('file-in').click()\">UPLOAD ARTWORK<\/button>\n                    <input type=\"file\" id=\"file-in\" accept=\"image\/*\" style=\"display:none;\" onchange=\"window.handleUpload(this)\">\n                <\/div>\n            <\/div>\n\n            <button class=\"acc-btn\" onclick=\"window.toggleAcc('acc-product')\">1. MAT OPTIONS <span>▼<\/span><\/button>\n            <div id=\"acc-product\" class=\"acc-content\">\n                <label style=\"font-size:10px; color:#aaa;\">Edge Finish<\/label>\n                <select id=\"var-sel\" class=\"ui-select\" onchange=\"window.updateATC()\"><\/select>\n                <label style=\"font-size:10px; color:#aaa;\">Quantity<\/label>\n                <input type=\"number\" id=\"qty-in\" value=\"1\" min=\"1\" class=\"ui-select\" style=\"width: 70px;\">\n            <\/div>\n\n            <button class=\"acc-btn\" onclick=\"window.toggleAcc('acc-layouts')\">2. GAME LAYOUTS <span>▼<\/span><\/button>\n            <div id=\"acc-layouts\" class=\"acc-content\">\n                <label style=\"font-size:10px; color:#aaa;\">Game<\/label>\n                <select id=\"game-sel\" class=\"ui-select\" onchange=\"window.filterFormats()\"><\/select>\n                \n                <div id=\"format-wrap\" class=\"hidden-field\">\n                    <label style=\"font-size:10px; color:#aaa;\">Format<\/label>\n                    <select id=\"format-sel\" class=\"ui-select\" onchange=\"window.filterHands()\"><\/select>\n                <\/div>\n\n                <div id=\"hand-wrap\" class=\"hidden-field\">\n                    <label style=\"font-size:10px; color:#aaa;\">Handedness<\/label>\n                    <select id=\"hand-sel\" class=\"ui-select\" onchange=\"window.applyFinalLayout()\"><\/select>\n                <\/div>\n\n                <div id=\"zone-style-wrap\" class=\"hidden-field\">\n                    <div class=\"slider-row\">\n                        <label>Zone Style<\/label>\n                        <select id=\"mode-sel\" class=\"ui-select\" onchange=\"window.refreshLayoutCSS()\">\n                            <option value=\"solid\">Solid Color<\/option>\n                            <option value=\"gradient\">Gradient<\/option>\n                        <\/select>\n                        <input type=\"color\" id=\"col-1\" value=\"#ffffff\" onchange=\"window.refreshLayoutCSS()\" style=\"width:100%; border:none; height:30px; background:none;\">\n                        \n                        <div id=\"grad-controls\" class=\"hidden-field\" style=\"margin-top:10px;\">\n                            <label>Secondary Color<\/label>\n                            <input type=\"color\" id=\"col-2\" value=\"#ff0000\" onchange=\"window.refreshLayoutCSS()\" style=\"width:100%; border:none; height:30px; background:none;\">\n                            <label style=\"margin-top:10px;\">Gradient Angle<\/label>\n                            <input type=\"range\" id=\"angle-in\" min=\"0\" max=\"360\" value=\"180\" oninput=\"window.refreshLayoutCSS()\">\n                        <\/div>\n                        \n                        <label style=\"margin-top:10px;\">Opacity<\/label>\n                        <input type=\"range\" id=\"op-in\" min=\"0.1\" max=\"1\" step=\"0.1\" value=\"1.0\" oninput=\"window.refreshLayoutCSS()\">\n                    <\/div>\n                <\/div>\n            <\/div>\n\n            <button class=\"acc-btn\" onclick=\"window.toggleAcc('acc-art')\">3. ART CONTROLS <span>▼<\/span><\/button>\n            <div id=\"acc-art\" class=\"acc-content\">\n                <button class=\"action-btn\" style=\"background:#444; border-radius:4px; padding:10px; margin-bottom:15px;\" onclick=\"window.forceFit()\">AUTO-FIT STRETCH<\/button>\n                <div class=\"slider-row\">\n                    <label>Manual Zoom<\/label>\n                    <input type=\"range\" id=\"zoom-in\" min=\"0.1\" max=\"3\" step=\"0.01\" value=\"1\" oninput=\"window.handleZoom(this.value)\">\n                <\/div>\n                <div style=\"margin-top:15px; display:flex; align-items:center; gap:10px;\">\n                    <input type=\"checkbox\" id=\"lock-border\" checked> <label style=\"font-size:11px;\">Lock to Borders<\/label>\n                <\/div>\n                <button class=\"action-btn\" style=\"background:#555; border-radius:4px; margin-top:15px; font-size:10px; padding:8px;\" onclick=\"window.toggleGuides()\">TOGGLE PRINT GUIDES<\/button>\n            <\/div>\n\n            <button class=\"acc-btn\" onclick=\"window.toggleAcc('acc-text')\">4. TEXT TOOL <span>▼<\/span><\/button>\n            <div id=\"acc-text\" class=\"acc-content\">\n                <button class=\"action-btn\" style=\"background:var(--green); border-radius:4px; padding:10px; margin-bottom:15px;\" onclick=\"window.addText()\">+ ADD TEXT<\/button>\n                <label style=\"font-size:10px; color:#aaa;\">Font Style<\/label>\n                <select id=\"font-family\" class=\"ui-select\" onchange=\"window.updateTextAttr('fontFamily', this.value)\">\n                    <option value=\"Rubik\">Rubik (Modern)<\/option>\n                    <option value=\"Bangers\">Bangers (Comic)<\/option>\n                    <option value=\"Permanent Marker\">Handwritten<\/option>\n                    <option value=\"Press Start 2P\">8-Bit Retro<\/option>\n                <\/select>\n                <div class=\"slider-row\">\n                    <label>Colors & Outline<\/label>\n                    <div style=\"display:flex; gap:5px;\">\n                        <input type=\"color\" id=\"text-col\" value=\"#ffffff\" onchange=\"window.updateTextAttr('fill', this.value)\" style=\"flex:1; height:30px; border:none; background:none;\">\n                        <input type=\"color\" id=\"text-stroke\" value=\"#000000\" onchange=\"window.updateTextAttr('stroke', this.value)\" style=\"flex:1; height:30px; border:none; background:none;\">\n                    <\/div>\n                    <input type=\"range\" min=\"0\" max=\"10\" value=\"0\" oninput=\"window.updateTextAttr('strokeWidth', parseInt(this.value))\" style=\"margin-top:10px;\">\n                <\/div>\n                <button class=\"action-btn\" style=\"background:#a72828; border-radius:4px; margin-top:15px; font-size:10px; padding:8px;\" onclick=\"window.removeActive()\">DELETE SELECTED<\/button>\n            <\/div>\n\n            <div style=\"padding: 20px;\">\n                <button id=\"sidebar-atc\" class=\"action-btn\" style=\"background:var(--brand); border-radius:6px; height: 60px;\" disabled onclick=\"window.submitToCart()\">ADD TO CART<\/button>\n            <\/div>\n        <\/div>\n\n        <div id=\"canvas-column\" style=\"flex-grow:1; display:flex; align-items:center; justify-content:center; padding:20px;\">\n            <div id=\"canvas-wrapper\">\n                <canvas id=\"main-canvas\"><\/canvas>\n                <div id=\"layout-mask-overlay\"><\/div>\n            <\/div>\n        <\/div>\n    <\/div>\n<\/div>\n\n<script src=\"https:\/\/cdnjs.cloudflare.com\/ajax\/libs\/fabric.js\/5.3.1\/fabric.min.js\"><\/script>\n\n<script>\n    \/\/ --- CORE SETUP ---\n    document.addEventListener(\"DOMContentLoaded\", () => {\n        const sSel = document.getElementById('size-sel');\n        for(let k in SIZE_DB) sSel.innerHTML += `<option value=\"${k}\">${SIZE_DB[k].label}<\/option>`;\n        const gSel = document.getElementById('game-sel');\n        gSel.innerHTML = '<option value=\"\">-- Select Game --<\/option>';\n        [...new Set(LAYOUT_RAW.map(i => i.game))].forEach(g => gSel.innerHTML += `<option value=\"${g}\">${g}<\/option>`);\n        window.initCanvas();\n    });\n\n    window.initCanvas = function() {\n        const wrap = document.getElementById('canvas-column');\n        const w = wrap.clientWidth - 40; const h = w \/ (24.5\/14.5);\n        window.canvas = new fabric.Canvas('main-canvas', { width: w, height: h, backgroundColor: '#000', preserveObjectStacking: true });\n        window.drawGuides(w, h, 24.5);\n        window.canvas.on('object:moving', (e) => {\n            if(!document.getElementById('lock-border').checked) return;\n            const obj = e.target; if(obj.name !== 'art') return;\n            obj.setCoords();\n            if(obj.left > 0) obj.left = 0; if(obj.top > 0) obj.top = 0;\n            if(obj.left + obj.getBoundingRect().width < window.canvas.width) obj.left = window.canvas.width - obj.getBoundingRect().width;\n            if(obj.top + obj.getBoundingRect().height < window.canvas.height) obj.top = window.canvas.height - obj.getBoundingRect().height;\n        });\n    };\n\n    window.refreshLayoutCSS = function() {\n        const o = document.getElementById('layout-mask-overlay');\n        const mode = document.getElementById('mode-sel').value;\n        const c1 = document.getElementById('col-1').value;\n        const c2 = document.getElementById('col-2').value;\n        const ang = document.getElementById('angle-in').value;\n        document.getElementById('grad-controls').style.display = (mode === 'gradient') ? 'block' : 'none';\n        o.style.opacity = document.getElementById('op-in').value;\n        o.style.background = (mode === 'solid') ? c1 : `linear-gradient(${ang}deg, ${c1}, ${c2})`;\n    };\n\n    \/\/ (Remaining utility functions: filterFormats, filterHands, applyFinalLayout, changeSize, drawGuides, handleUpload, forceFit, handleZoom, addText, updateTextAttr, toggleAcc, updateATC, toggleGuides, removeActive, submitToCart are preserved from previous version but integrated here)\n    window.filterFormats = function() {\n        const game = document.getElementById('game-sel').value;\n        const curSize = document.getElementById('size-sel').options[document.getElementById('size-sel').selectedIndex].text.split(' ')[0];\n        const wrap = document.getElementById('format-wrap');\n        const fSel = document.getElementById('format-sel');\n        if(!game) { wrap.classList.add('hidden-field'); return; }\n        wrap.classList.remove('hidden-field');\n        fSel.innerHTML = '<option value=\"\">-- Format --<\/option>';\n        const formats = [...new Set(LAYOUT_RAW.filter(i => i.game === game && i.size === curSize).map(i => i.format))];\n        formats.forEach(f => fSel.innerHTML += `<option value=\"${f}\">${f}<\/option>`);\n    };\n\n    window.filterHands = function() {\n        const game = document.getElementById('game-sel').value;\n        const format = document.getElementById('format-sel').value;\n        const curSize = document.getElementById('size-sel').options[document.getElementById('size-sel').selectedIndex].text.split(' ')[0];\n        const wrap = document.getElementById('hand-wrap');\n        const hSel = document.getElementById('hand-sel');\n        if(!format) { wrap.classList.add('hidden-field'); return; }\n        wrap.classList.remove('hidden-field');\n        hSel.innerHTML = '<option value=\"\">-- Handedness --<\/option>';\n        const hands = [...new Set(LAYOUT_RAW.filter(i => i.game === game && i.format === format && i.size === curSize).map(i => i.hand))];\n        hands.forEach(h => hSel.innerHTML += `<option value=\"${h}\">${h}<\/option>`);\n    };\n\n    window.applyFinalLayout = function() {\n        const game = document.getElementById('game-sel').value;\n        const format = document.getElementById('format-sel').value;\n        const hand = document.getElementById('hand-sel').value;\n        const curSize = document.getElementById('size-sel').options[document.getElementById('size-sel').selectedIndex].text.split(' ')[0];\n        const match = LAYOUT_RAW.find(i => i.game === game && i.format === format && i.hand === hand && i.size === curSize);\n        if(match) {\n            document.getElementById('zone-style-wrap').classList.remove('hidden-field');\n            const o = document.getElementById('layout-mask-overlay');\n            o.style.display = 'block'; o.style.webkitMaskImage = `url(${match.url})`; o.style.maskImage = `url(${match.url})`;\n            o.setAttribute('data-url', match.url); window.refreshLayoutCSS();\n        }\n    };\n\n    window.changeSize = function() {\n        const k = document.getElementById('size-sel').value; if(!k) return;\n        const conf = SIZE_DB[k];\n        const vSel = document.getElementById('var-sel');\n        vSel.innerHTML = ''; conf.variants.forEach(v => vSel.innerHTML += `<option value=\"${v.id}\">${v.name}<\/option>`);\n        const w = document.getElementById('canvas-column').clientWidth - 40; const h = w \/ (conf.w \/ conf.h);\n        window.canvas.setDimensions({ width: w, height: h });\n        window.canvas.getObjects().forEach(o => { if(o.name==='guides') window.canvas.remove(o) });\n        window.drawGuides(w, h, conf.w); window.forceFit(); \n    };\n\n    window.drawGuides = function(w, h, inches) {\n        const ppi = w \/ inches; const b = 0.25 * ppi, s = 0.50 * ppi;\n        const g = new fabric.Group([\n            new fabric.Rect({left:0, top:0, width:w, height:b, fill:'rgba(255,0,0,0.3)', selectable:false}),\n            new fabric.Rect({left:0, top:h-b, width:w, height:b, fill:'rgba(255,0,0,0.3)', selectable:false}),\n            new fabric.Rect({left:0, top:b, width:b, height:h-(b*2), fill:'rgba(255,0,0,0.3)', selectable:false}),\n            new fabric.Rect({left:w-b, top:b, width:b, height:h-(b*2), fill:'rgba(255,0,0,0.3)', selectable:false})\n        ], { selectable: false, evented: false, name: 'guides' });\n        window.canvas.add(g);\n    };\n\n    window.handleUpload = function(input) {\n        const r = new FileReader();\n        r.onload = (f) => {\n            fabric.Image.fromURL(f.target.result, (img) => {\n                img.set({ name: 'art' });\n                window.canvas.getObjects().forEach(o => { if(o.name==='art') window.canvas.remove(o) });\n                window.canvas.add(img); window.forceFit(); img.sendToBack();\n            }, { crossOrigin: 'anonymous' });\n        };\n        r.readAsDataURL(input.files[0]);\n    };\n\n    window.forceFit = function() {\n        const img = window.canvas.getObjects().find(o => o.name === 'art'); if(!img) return;\n        img.set({ scaleX: window.canvas.width \/ img.width, scaleY: window.canvas.height \/ img.height, left: 0, top: 0 });\n        window.canvas.renderAll();\n    };\n\n    window.handleZoom = function(val) {\n        const img = window.canvas.getObjects().find(o => o.name === 'art'); if(!img) return;\n        img.scale(parseFloat(val)); window.canvas.renderAll();\n    };\n\n    window.addText = function() {\n        const t = new fabric.IText(\"Double Click\", { left: 50, top: 50, fill: '#fff', fontSize: 40, fontFamily: 'Rubik', stroke: '#000', strokeWidth: 0, paintFirst: 'stroke' });\n        window.canvas.add(t).setActiveObject(t).renderAll();\n    };\n\n    window.updateTextAttr = function(attr, val) {\n        const obj = window.canvas.getActiveObject();\n        if(obj && obj.type === 'i-text') { obj.set(attr, val); window.canvas.renderAll(); }\n    };\n\n    window.toggleAcc = (id) => { document.querySelectorAll('.acc-content').forEach(c => c.style.display = 'none'); document.getElementById(id).style.display = 'block'; };\n    window.updateATC = () => { document.getElementById('sidebar-atc').disabled = !document.getElementById('var-sel').value; };\n    window.toggleGuides = () => { const g = window.canvas.getObjects().find(o => o.name === 'guides'); g.visible = !g.visible; window.canvas.renderAll(); };\n    window.removeActive = () => { window.canvas.remove(window.canvas.getActiveObject()); window.canvas.renderAll(); };\n\n    window.submitToCart = function() {\n        const btn = document.getElementById('sidebar-atc'); btn.innerText = \"Baking...\"; btn.disabled = true;\n        const guides = window.canvas.getObjects().find(o => o.name === 'guides'); if(guides) guides.visible = false;\n        const dataURL = window.canvas.toDataURL({ format: 'jpeg', multiplier: 2 });\n        const body = JSON.stringify({ items: [{ id: document.getElementById('var-sel').value, quantity: document.getElementById('qty-in').value, properties: { '_Design': dataURL } }] });\n        fetch('\/cart\/add.js', { method: 'POST', headers: {'Content-Type': 'application\/json'}, body }).then(() => location.href = '\/cart');\n    };\n<\/script>","color_scheme":"","section_width":"page-width","padding-block-start":50,"padding-block-end":0}}},"order":["main","custom_liquid_GMq88c"]}