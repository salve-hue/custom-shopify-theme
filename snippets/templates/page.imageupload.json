{"sections":{"section_XrrJ8M":{"type":"section","blocks":{"text_RQcQdp":{"type":"text","name":"Title","settings":{"text":"<p>Subscriptions - Upload Your Image<\/p>","width":"100%","max_width":"none","alignment":"left","type_preset":"h3","font":"var(--font-primary--family)","font_size":"","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"divider_UCTLmF":{"type":"_divider","name":"t:names.divider","settings":{"thickness":5,"divider_color":"#df5918","corner_radius":"rounded","width_percent":100,"padding-block-start":0,"padding-block-end":0},"blocks":{}},"text_jbddAy":{"type":"text","name":"t:names.text","settings":{"text":"<p>Use the form below to upload images for your subscriptions. Images must be pre-cropped to the proper aspect ratio (see below).<\/p><p>• 24\" x 14\" Playmats — 49:29<br\/>• 28\" x 14\" Playmats — 57:29<\/p><p>Don't forget to include your order number and name\/email, in case we need to track it back.<\/p><p><\/p>","width":"100%","max_width":"none","alignment":"left","type_preset":"h4","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":20,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"text_ALA77J":{"type":"text","name":"t:names.text","disabled":true,"settings":{"text":"<p>• 24\" x 14\" Playmats — 49:29<br\/>• 28\" x 14\" Playmats — 57:29<\/p><p>Don't forget to include your order number and name\/email, in case we need to track it back.<\/p><p>If you need assistance with formatting your images, you can check out our Guides Section or shoot us an email on our contact form.<\/p>","width":"100%","max_width":"none","alignment":"left","type_preset":"h4","font":"var(--font-body--family)","font_size":"1.125rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":25,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_RQcQdp","divider_UCTLmF","text_jbddAy","text_ALA77J"],"name":"t:names.custom_section","settings":{"content_direction":"column","vertical_on_mobile":true,"horizontal_alignment":"flex-start","vertical_alignment":"center","align_baseline":false,"horizontal_alignment_flex_direction_column":"flex-start","vertical_alignment_flex_direction_column":"center","gap":12,"section_width":"page-width","section_height":"custom","section_height_custom":25,"color_scheme":"","background_media":"none","video_position":"cover","background_image_position":"cover","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"toggle_overlay":false,"overlay_color":"#00000026","overlay_style":"solid","gradient_direction":"to top","padding-block-start":0,"padding-block-end":0}},"section_8qmBJg":{"type":"section","blocks":{"group_inj89x":{"type":"group","name":"t:names.group","settings":{"content_direction":"column","vertical_on_mobile":true,"horizontal_alignment":"flex-start","vertical_alignment":"center","align_baseline":false,"horizontal_alignment_flex_direction_column":"flex-start","vertical_alignment_flex_direction_column":"center","gap":12,"width":"fit-content","custom_width":100,"width_mobile":"fit-content","custom_width_mobile":100,"height":"fit","custom_height":100,"inherit_color_scheme":true,"color_scheme":"","background_media":"none","video_position":"cover","background_image_position":"cover","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"toggle_overlay":false,"overlay_color":"#00000026","overlay_style":"solid","gradient_direction":"to top","link":"","open_in_new_tab":false,"placeholder":"","padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{"text_zyVCzj":{"type":"text","name":"t:names.text","settings":{"text":"<p><strong>Want to use our image tool to crop your image?<\/strong><\/p><p>Our current upload tool is limited to pre-sales uploads, meaning it can only be attached to a new product purchase.<\/p><p>However, you can use the tool to upload your image, crop it, and download it in the proper format. Follow these steps (works on PCs and mobile devices).<\/p><p>• Navigate to the correct playmat product page, as if you were going to purchase one new: <a href=\"https:\/\/www.rubicongamesupplies.com\/products\/custom-tcg-playmat-with-your-art-10664\" target=\"_blank\" title=\"https:\/\/www.rubicongamesupplies.com\/products\/custom-tcg-playmat-with-your-art-10664\"><strong>24\" x 14\"<\/strong><\/a> or <a href=\"https:\/\/www.rubicongamesupplies.com\/products\/custom-playmat-28-x-14\" target=\"_blank\" title=\"https:\/\/www.rubicongamesupplies.com\/products\/custom-playmat-28-x-14\"><strong>28\" x 14\".<\/strong><\/a><\/p><p>•Click <strong>Choose File<\/strong>, select your image, and crop it as needed. Click <strong>Done.<\/strong><\/p><p>• Add the item to your cart. Then, open your cart. You will see a thumbnail of the image you uploaded. <strong>Click the thumbnail<\/strong> to go to a page to download your photo.<\/p><p>• Download your image and submit it below.<\/p>","width":"fit-content","max_width":"normal","alignment":"left","type_preset":"h4","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":true,"background_color":"#ff3e3e81","corner_radius":6,"padding-block-start":20,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_zyVCzj"]},"ai_gen_block_cf9088a_ycGbQU":{"type":"ai_gen_block_cf9088a","disabled":true,"settings":{"button_text":"Click Here for a Cropping Workaround","show_icon":true,"button_alignment":"center","button_font_size":18,"button_font_weight":"500","button_padding_vertical":12,"button_padding_horizontal":24,"button_border_radius":6,"button_border_width":0,"section_padding":20,"button_bg_color":"#df1818","button_text_color":"#ffffff","button_border_color":"#000000","button_hover_bg_color":"#333333","button_hover_text_color":"#ffffff","button_hover_border_color":"#333333","lightbox_title":"How to use our current image upload tool to format your art for subscription purchases.","lightbox_content":"<p>Our current upload tool is limited to pre-sales uploads, meaning it can only be attached to a new product purchase.<\/p><p>However, you can use the tool to upload your image, crop it, and download it in the proper format. Follow these steps (works on PCs and mobile devices).<\/p><ul><li>Navigate to the correct playmat product page, as if you were going to purchase one new: <a href=\"https:\/\/www.rubicongamesupplies.com\/products\/custom-tcg-playmat-with-your-art-10664\" target=\"_blank\" title=\"https:\/\/www.rubicongamesupplies.com\/products\/custom-tcg-playmat-with-your-art-10664\"><strong>24\" x 14\"<\/strong><\/a> or <a href=\"https:\/\/www.rubicongamesupplies.com\/products\/custom-playmat-28-x-14\" target=\"_blank\" title=\"https:\/\/www.rubicongamesupplies.com\/products\/custom-playmat-28-x-14\"><strong>28\" x 14\".<\/strong><\/a><\/li><li>Click <strong>Choose File<\/strong>, select your image, and crop it as needed. Click <strong>Done.<\/strong><\/li><li>Add the item to your cart. Then, open your cart. You will see a thumbnail of the image you uploaded. <strong>Click the thumbnail<\/strong> to go to a page to download your photo.<\/li><li>Download your image and submit it below.<\/li><\/ul>","lightbox_max_width":600,"lightbox_padding":24,"lightbox_border_radius":6,"title_font_size":24,"lightbox_bg_color"