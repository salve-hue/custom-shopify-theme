{"sections":{"cart-section":{"type":"main-cart","blocks":{"custom_liquid_K7PGTV":{"type":"custom-liquid","name":"Gaming Essentials Add-ons","settings":{"custom_liquid":"<style>\n  :root {\n    --upsell-btn-bg: #DF5918;      \/* Your Primary Orange *\/\n    --upsell-btn-hover: #02B6FA;   \/* Your Hover Blue *\/\n    --modal-z-index: 999999;\n    --base-font-size: 12pt;\n  }\n\n  .bundle-container {\n    border: 1px solid #eee;\n    padding: 20px;\n    border-radius: 8px;\n    background: #fff;\n    font-size: var(--base-font-size);\n    line-height: 1.4;\n    color: #333;\n\nmax-width: 800px;   \/* Adjust this number to your liking *\/\n    margin: 0 auto;     \/* This centers the box if it's smaller than the screen *\/\n  }\n\n  .bundle-header h3 {\n    margin: 0 0 4px 0;\n    font-size: 16pt;\n    font-weight: bold;\n  }\n\n  .bundle-header p {\n    margin: 0 0 15px 0;\n    font-size: 14pt;\n    color: #666;\n  }\n\n  .bundle-item {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 10px 0;\n    border-bottom: 1px solid #f2f2f2;\nfont-size: 14pt;\n  }\n\n  .bundle-item:last-child { border-bottom: none; }\n\n  .bundle-info { display: flex; align-items: center; gap: 12px; }\n  .bundle-img { width: 50px; height: 50px; border-radius: 4px; object-fit: cover; }\n  .bundle-title { font-weight: bold; margin: 0; font-size: 1em; }\n\n  .add-bundle-btn {\n    background-color: var(--upsell-btn-bg);\n    color: #fff;\n    border: none;\n    padding: 8px 14px;\n    border-radius: 4px;\n    cursor: pointer;\n    font-size: 11pt;\n    font-weight: 600;\n    transition: background-color 0.2s ease-in-out;\n    min-width: 90px;\n  }\n\n  .add-bundle-btn:hover {\n    background-color: var(--upsell-btn-hover);\n  }\n\n  \/* MODAL STYLES *\/\n  #upsell-modal-overlay {\n    display: none;\n    position: fixed;\n    top: 0; left: 0; width: 100%; height: 100%;\n    background: rgba(0, 0, 0, 0.5);\n    z-index: var(--modal-z-index);\n    align-items: center;\n    justify-content: center;\n  }\n\n  .modal-box {\n    background: white;\n    width: 90%;\n    max-width: 400px;\n    padding: 25px;\n    border-radius: 10px;\n    position: relative;\n    font-size: var(--base-font-size);\n  }\n\n  .variant-option {\n    display: flex;\n    align-items: center;\n    padding: 10px;\n    border: 1px solid #eee;\n    margin-bottom: 8px;\n    cursor: pointer;\n    border-radius: 6px;\n    transition: all 0.2s;\n  }\n\n  .variant-option:hover { \n    background: #fafafa; \n    border-color: var(--upsell-btn-hover); \n  }\n\n  .swatch-box {\n    width: 20px;\n    height: 20px;\n    border-radius: 3px;\n    margin-right: 10px;\n    flex-shrink: 0;\n    border: 1px solid rgba(0,0,0,0.1);\n  }\n\n  .variant-name { flex-grow: 1; font-weight: 500; }\n  .variant-price { font-weight: bold; margin-right: 8px; }\n  .arrow-indicator { color: #ccc; }\n\n  .close-x {\n    position: absolute;\n    top: 10px; right: 15px;\n    font-size: 20px; cursor: pointer;\n  }\n<\/style>\n\n<div class=\"bundle-container\">\n  <div class=\"bundle-header\">\n    <h3>Gaming Essentials Add-ons<\/h3>\n    <p>Need some extra gear? Check out these essentials.<\/p>\n  <\/div>\n  \n  {% assign collection = collections['gaming-essentials'] %}\n  \n  {% for product in collection.products limit: 4 %}\n    <div class=\"bundle-item\">\n      <div class=\"bundle-info\">\n        <img src=\"{{ product.featured_image | img_url: '100x' }}\" class=\"bundle-img\">\n        <div class=\"bundle-text\">\n          <p class=\"bundle-title\">{{ product.title }}<\/p>\n          <p style=\"margin:0; font-size: 0.9em; color: #777;\">{{ product.price | money }}<\/p>\n        <\/div>\n      <\/div>\n\n      {% if product.variants.size > 1 %}\n        <button class=\"add-bundle-btn\" onclick=\"openUpsell('{{ product.id }}')\">Options<\/button>\n        <script id=\"json-{{ product.id }}\" type=\"application\/json\">\n          {\n            \"title\": {{ product.title | json }},\n            \"variants\": [\n              {% for variant in product.variants %}\n                {\n                  \"id\": {{ variant.id }},\n                  \"title\": {{ variant.title | json }},\n                  \"price\": {{ variant.price | money | json }},\n                  \"color\": {{ variant.title | handle | json }}\n                }{% unless forloop.last %},{% endunless %}\n              {% endfor %}\n            ]\n          }\n        <\/script>\n      {% else %}\n        <button class=\"add-bundle-btn\" onclick=\"quickAdd({{ product.first_available_variant.id }}, this)\">Add +<\/button>\n      {% endif %}\n    <\/div>\n  {% endfor %}\n<\/div>\n\n<div id=\"upsell-modal-overlay\" style=\"display:none;\">\n  <div class=\"modal-box\">\n    <span class=\"close-x\" onclick=\"closeUpsell()\">&times;<\/span>\n    <p id=\"modal-title\" style=\"margin: 0 0 15px 0; font-weight:bold;\">Select Option<\/p>\n    <div id=\"variant-list-container\"><\/div>\n  <\/div>\n<\/div>\n\n<script>\nfunction openUpsell(productId) {\n  const data = JSON.parse(document.getElementById('json-' + productId).innerHTML);\n  const list = document.getElementById('variant-list-container');\n  document.getElementById('modal-title').innerText = data.title;\n  list.innerHTML = '';\n\n  data.variants.forEach(v => {\n    const item = document.createElement('div');\n    item.className = 'variant-option';\n    item.onclick = () => quickAdd(v.id);\n    \n    let colorStyle = '#eeeeee';\n    const commonColors = ['black', 'white', 'red', 'blue', 'green', 'yellow', 'purple', 'pink', 'orange', 'grey', 'gray'];\n    let found = commonColors.find(c => v.color.includes(c));\n    if(found) {\n        if(found === 'black') colorStyle = '#000000';\n        else if(found === 'white') colorStyle = '#ffffff';\n        else colorStyle = found;\n    }\n    \n    item.innerHTML = `\n      <div class=\"swatch-box\" style=\"background-color: ${colorStyle};\"><\/div>\n      <div class=\"variant-name\">${v.title}<\/div>\n      <div class=\"variant-price\">${v.price}<\/div>\n      <div class=\"arrow-indicator\">→<\/div>\n    `;\n    list.appendChild(item);\n  });\n\n  document.getElementById('upsell-modal-overlay').style.display = 'flex';\n}\n\nfunction closeUpsell() {\n  document.getElementById('upsell-modal-overlay').style.display = 'none';\n}\n\nfunction quickAdd(id, btn = null) {\n  if(btn) { \n    btn.style.backgroundColor = '#ccc';\n    btn.innerText = '...'; \n    btn.disabled = true; \n  }\n  \n  fetch(window.Shopify.routes.root + 'cart\/add.js', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application\/json' },\n    body: JSON.stringify({ 'items': [{ 'id': id, 'quantity': 1 }] })\n  })\n  .then(res => res.json())\n  .then(data => {\n    window.location.reload();\n  })\n  .catch(err => {\n    console.error(err);\n    if(btn) { \n        btn.innerText = 'Error'; \n        btn.style.backgroundColor = 'red';\n        btn.disabled = false; \n    }\n  });\n}\n\ndocument.getElementById('upsell-modal-overlay').addEventListener('click', function(e) {\n  if (e.target === this) closeUpsell();\n});\n<\/script>"},"blocks":{}},"cart-page-title":{"type":"_cart-title","static":true,"settings":{"title":"Cart","show_count":true,"type_preset":"h4","alignment":"left","padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"cart-page-items":{"type":"_cart-products","static":true,"settings":{"gap":24,"image_ratio":"portrait","dividers":true,"vendor":false,"padding-block-start":0,"padding-block-end":100,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}},"cart-page-summary":{"type":"_cart-summary","static":true,"settings":{"extend_summary":true,"inherit_color_scheme":false,"color_scheme":"scheme-2","border":"none","border_width":1,"border_opacity":100,"border_radius":0},"blocks":{}}},"block_order":["custom_liquid_K7PGTV"],"settings":{"section_width":"page-width","color_scheme":"","padding-block-start":24,