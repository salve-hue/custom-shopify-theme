        "ai_gen_block_a05ed92_JByWDV": {
          "type": "ai_gen_block_a05ed92",
          "name": "The Journey",
          "settings": {
            "content": "<ul><li><strong>Sourcing the Materials<\/strong>: We start by sourcing materials that meet or exceed our—and most importantly—your standards. We  work exclusively with 3 mm neoprene mats, but can source any thickness.<\/li><li><strong>Bringing Your Art to Life<\/strong>: We use a special ink-bonding process called dye sublimation that locks your design directly into the fabric. It means colors stay bright and details stay sharp, even after hundreds of sessions.<\/li><li><strong>Heat Press Activation<\/strong>: Every mat gets pressed by heat to bond the ink to the playmat. Once this step is completed, your mats are colorful, vibrant, and smooth to the touch.<\/li><li><strong>Getting it to the Table<\/strong>: Once they’re finished, we handle the boring logistics and heavy lifting to make sure your mats show up at your backers' doors right on time.<\/li><\/ul>",
            "font_family": "rubik_n4",
            "font_size": 16,
            "line_height": "1.5",
